@inherits LayoutComponentBase

@inject IUserContextService userContext
@inject NavigationManager Navigation

<div class="layout-container">

    <!-- Sidebar (full height, left) -->
    <nav class="@sidebarClass">

        <!-- Sidebar Header: Encoder -->
        <div class="sidebar-header">
            <h5 class="sidebar-label">Encoder</h5>
        </div>

        <ul class="sidebar-menu">

            <li>
                <NavLink class="sidebar-link"
                         href="home"
                         Match="NavLinkMatch.All">
                    <span class="bi bi-house-door-fill"></span>
                    <span class="sidebar-label">Home</span>
                </NavLink>
            </li>

            <li>
                <NavLink class="sidebar-link"
                         href="mapitem">
                    <span class="bi bi-plus-square-fill"></span>
                    <span class="sidebar-label">Map Items</span>
                </NavLink>
            </li>
            <li>
                <NavLink class="sidebar-link"
                         href="customer">
                    <span class="bi bi-plus-square-fill"></span>
                    <span class="sidebar-label">Customers</span>
                </NavLink>
            </li>


            <li>
                <NavLink class="sidebar-link"
                         href="profile">
                    <span class="bi bi-person"></span>
                    <span class="sidebar-label">Profile</span>
                </NavLink>
            </li>

            <li>
                <NavLink class="sidebar-link"
                         href="settings">
                    <span class="bi bi-gear"></span>
                    <span class="sidebar-label">Settings</span>
                </NavLink>
            </li>

            <li>
                <NavLink class="sidebar-link"
                         href="help">
                    <span class="bi bi-question-circle"></span>
                    <span class="sidebar-label">Help</span>
                </NavLink>
            </li>

        </ul>

    </nav>

    <!-- Right Column: TopBar + Content -->
    <div class="right-column">

        <UserTopBar OnHamburgerClick="ToggleSidebar" />

        <main class="main-content">
            @Body
        </main>

    </div>

</div>

@code {
    private bool sidebarOpen = true;

    private string sidebarClass => sidebarOpen ? "sidebar sidebar-open" : "sidebar sidebar-closed";

    private Task ToggleSidebar()
    {
        sidebarOpen = !sidebarOpen;
        StateHasChanged();
        return Task.CompletedTask;
    }
}
