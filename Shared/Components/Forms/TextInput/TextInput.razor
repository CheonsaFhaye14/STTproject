@using Microsoft.AspNetCore.Components.Forms
@using System.Linq.Expressions

@if (!string.IsNullOrWhiteSpace(Label))
{
    <label class="form-label">
        @Label
        @if (Required)
        {
            <span class="text-danger">*</span>
        }
    </label>
}

<InputText
    @ref="ElementRef"
    class="@($"form-control {Class}")"
    placeholder="@Placeholder"
    disabled="@Disabled"
    readonly="@ReadOnly"
    @bind-Value="Value"
    data-focus-order="@FocusOrder"
    data-can-move-next="@(CanMoveNext && FocusOrder.HasValue ? "true" : "false")"
    data-autofocus="@(AutoFocus ? "true" : null)" />

@if (For is not null)
{
    <ValidationMessage For="For" />
}

@code {
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public int? FocusOrder { get; set; }
    [Parameter] public bool CanMoveNext { get; set; } = true;
    [Parameter] public bool AutoFocus { get; set; }         // ✅ was missing
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public Expression<Func<string?>>? For { get; set; }

    public InputText? ElementRef { get; set; }             // ✅ was missing
}