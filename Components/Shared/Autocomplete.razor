@using STTproject.Models
@using STTproject.Services
@using Microsoft.JSInterop
@using STTproject.Data
@using STTproject.Features.MapItem.DTOs
@namespace STTproject.Components.Shared


<div class="autocomplete">
    <input class="form-input" @ref="inputRef" @bind-value="Value" @bind-value:event="oninput" @onkeydown="OnKeyDown"
           @onfocus="OpenOnFocus" @onblur="HandleBlur" placeholder="@Placeholder" disabled="@IsDisabled" />
    @if (isOpen && FilteredItems.Any())
    {
        <div class="autocomplete-popup" @onmousedown:preventDefault>
            @foreach (var (item, idx) in FilteredItems.Select((it, i) => (it, i)))
            {
                var cls = idx == highlightedIndex ? "autocomplete-item highlighted" : "autocomplete-item";
                <div class="@cls" @onclick="() => SelectItem(item)" @onmouseover="() => highlightedIndex = idx">
                    @GetDisplayText(item)</div>
                }
            </div>
        }
    </div>

@code {
    [Inject] IJSRuntime JSRuntime { get; set; } = default!;

    [Parameter] public List<CompanyItemDropdownItem> Items { get; set; } = new();
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public EventCallback<CompanyItemDropdownItem?> OnSelected { get; set; }
    [Parameter] public EventCallback OnConfirmed { get; set; }
    [Parameter] public string Placeholder { get; set; } = string.Empty;
    [Parameter] public bool IsDisabled { get; set; }

    private ElementReference inputRef;
    private bool isOpen = false;
    private int highlightedIndex = -1;
    private bool hasSelectedItem = false;

    private static string GetDisplayText(CompanyItemDropdownItem item)
        => string.IsNullOrWhiteSpace(item.ItemCode)
            ? item.ItemName
            : $"({item.ItemCode}) {item.ItemName}";

    private IEnumerable<CompanyItemDropdownItem> FilteredItems =>
        string.IsNullOrWhiteSpace(Value)
            ? Items
            : Items.Where(i => i.ItemName.Contains(Value, StringComparison.OrdinalIgnoreCase));

    private string? _previousValue;

    protected override async Task OnParametersSetAsync()
    {
        if (_previousValue != Value)
        {
            _previousValue = Value;
            highlightedIndex = -1;
            hasSelectedItem = false;
            await InvokeAsync(StateHasChanged);
        }
        await base.OnParametersSetAsync();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "ArrowDown")
        {
            if (!isOpen) isOpen = true;
            highlightedIndex = Math.Min(highlightedIndex + 1, FilteredItems.Count() - 1);
            await InvokeAsync(StateHasChanged);
            await Task.Delay(10);
            await ScrollToHighlighted();
            return;
        }

        if (e.Key == "ArrowUp")
        {
            highlightedIndex = Math.Max(highlightedIndex - 1, 0);
            await InvokeAsync(StateHasChanged);
            await Task.Delay(10);
            await ScrollToHighlighted();
            return;
        }

        if (e.Key == "Enter")
        {
            if (!isOpen && !hasSelectedItem)
            {
                isOpen = true;
                await InvokeAsync(StateHasChanged);
                return;
            }

            if (isOpen)
            {
                var toSelect = highlightedIndex >= 0 ? FilteredItems.ElementAt(highlightedIndex) : FilteredItems.FirstOrDefault();
                if (toSelect != null)
                {
                    await SelectItem(toSelect);
                }

                await OnConfirmed.InvokeAsync();
                return;
            }

            if (hasSelectedItem)
            {
                // Allow Enter to move focus to next element
                return;
            }
        }

        if (e.Key == "Escape")
        {
            isOpen = false;
            highlightedIndex = -1;
            await InvokeAsync(StateHasChanged);
            return;
        }
    }

    private async Task ScrollToHighlighted()
    {
        if (highlightedIndex >= 0)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("scrollHighlightedIntoView");
            }
            catch
            {
                // Fallback if JS function not available
            }
        }
    }

    private void OpenOnFocus(FocusEventArgs _)
    {
        isOpen = true;
        if (FilteredItems.Any() && highlightedIndex == -1)
        {
            highlightedIndex = 0;
        }
    }

    private async Task SelectItem(CompanyItemDropdownItem? item)
    {
        if (item == null) return;
        Value = item.ItemName;
        await ValueChanged.InvokeAsync(Value);
        isOpen = false;
        highlightedIndex = -1;
        hasSelectedItem = true;
        await OnSelected.InvokeAsync(item);
    }

    private void HandleBlur(FocusEventArgs args)
    {
        // Delay closing so click events on popup can register
        Task.Run(async () =>
        {
            await Task.Delay(150); isOpen = false; highlightedIndex = -1; await InvokeAsync(StateHasChanged);
        });
    }

    public async Task OpenPopupAsync()
    {
        isOpen = true;
        highlightedIndex = FilteredItems.Any() ? 0 : -1;
        await InvokeAsync(StateHasChanged);
        await inputRef.FocusAsync();
    }

    public ElementReference GetInputRef() => inputRef;
}
