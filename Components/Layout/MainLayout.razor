@inherits LayoutComponentBase

<div class="page">

    <main>
        <div class="top-row">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All" tabindex="-1">
                    <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="mapitem" tabindex="-1">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Map Items
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="profile" tabindex="-1">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Profile
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="settings" tabindex="-1">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Settings
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="help" tabindex="-1">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Help
                </NavLink>
            </div>

        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
