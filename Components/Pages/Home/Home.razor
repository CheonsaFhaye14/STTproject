@page "/"
@using STTproject.Components.Helper
@using System.Linq
@using STTproject.Models
@using STTproject.Services
@using STTproject.Components.Shared
@rendermode InteractiveServer

@inject IHomeService homeService
@inject IUserContextService userContext
@inject NavigationManager Navigation


<div class="title">
    <h2>Hello, @UserFullName</h2>
</div>

<!-- CARDS -->
<div class="cards">
    @foreach (var subd in subdList)
    {
        <div class="card">

            <div class="card-content">
                <div class="card-text">
                    
                    <h4>@subd.SubdCode</h4>
                    <div class="subdname">
                        <h3>@FormatHelper.ToAllCaps(subd.SubdName)</h3>
                    </div>
                   
                    <p>@FormatHelper.FormatLocation(subd.CityMunicipality, subd.Province ?? string.Empty)</p>
                </div>

                <button class="example" @onclick="() => InputSalesInvoice(subd.SubDistributorId)">
                    INPUT INVOICE
                </button>
            </div>

             
        </div>
    }
</div>

<!-- RECENT ACTIVITY Table to be moved-->
<div class="activity">
    <h3>Recent Activity...</h3>

    <!-- FILTERS -->
    <div class="filters">
        <!-- VIEW MODE TOGGLE - Combined button -->
        <div class="filter-group view-toggle">
            <button class="@(currentViewMode == "batch" ? "btn-toggle active" : "btn-toggle")"
                    @onclick="ToggleViewMode">
                @(currentViewMode == "batch" ? "Batch View" : "Invoice List")
            </button>
        </div>

        <div class="filter-group">
            <label>SUB DISTRIBUTOR</label>
            <select @bind="selectedSubdNameFilter">
                <option value="">ALL</option>
                @foreach (var subd in subdList)
                {
                    <option value="@subd.SubdName">@subd.SubdName</option>
                }
            </select>
        </div>

        <div class="filter-group">
            <label>INVOICE DATE</label>
            <input type="date" @bind="selectedDateFilter" />
        </div>

    </div>

    <!-- BATCH VIEW (Grouped View) -->
    @if (currentViewMode == "batch")
    {
        <table class="activity-table">
            <thead>
                <tr>
                    <th>BATCH NAME</th>
                    <th>SubDistributor Name</th>
                    <th>Invoice Date Range</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (FilteredBatchRows.Any())
                {
                    @foreach (var row in FilteredBatchRows)
                    {
                        <tr>
                            <td>@row.BatchId</td>
                            <td>@row.SubdName</td>
                            <td>
                                @if (row.LatestInvoiceDate == row.OldestInvoiceDate)
                                {
                                    @row.LatestInvoiceDate.ToString("yyyy-MM-dd")
                                }
                                else
                                {
                                    @($"{row.OldestInvoiceDate:yyyy-MM-dd} – {row.LatestInvoiceDate:yyyy-MM-dd}")
                                }
                            </td>
                            <td>
                                <button class="btn-primary" @onclick="() => OpenBatchDetailsAsync(row)">View Details</button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4">No sales invoice activity found.</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <!-- FLAT VIEW (Invoice List) -->
    @if (currentViewMode == "flat")
    {
        <table class="activity-table">
            <thead>
                <tr>
                    <th>Invoice Code</th>
                    <th>Sales Invoice Date</th>
                    <th>SubDistributor Name</th>
                    <th>Customer Name</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (FilteredFlatRows.Any())
                {
                    @foreach (var row in FilteredFlatRows)
                    {
                        <tr>
                            <td>@row.InvoiceCode</td>
                            <td>@row.SalesInvoiceDate.ToString("yyyy-MM-dd")</td>
                            <td>@row.SubdName</td>
                            <td>@row.CustomerName</td>
                            <td>
                                <button class="btn-primary" @onclick="() => OpenInvoiceDetailsAsync(row)">View Details</button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5">No sales invoice found.</td>
                    </tr>
                }
            </tbody>
        </table>
    }

</div>

@if (showBatchDetailsModal)
{
    <div class="modal-overlay" @onclick="CloseBatchDetails">
        <div class="modal-box batch-details-modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h4>Batch Details: @selectedBatchId</h4>
            </div>
            <div class="modal-body">
                <table class="activity-table">
                    <thead>
                        <tr>
                            <th>Invoice Code</th>
                            <th>Sales Invoice Date</th>
                            <th>SubDistributor Name</th>
                            <th>Customer Name</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (selectedBatchInvoices.Any())
                        {
                            @foreach (var invoiceRow in selectedBatchInvoices)
                            {
                                <tr>
                                    <td>@invoiceRow.InvoiceCode</td>
                                    <td>@invoiceRow.SalesInvoiceDate.ToString("yyyy-MM-dd")</td>
                                    <td>@invoiceRow.SubdName</td>
                                    <td>@invoiceRow.CustomerName</td>
                                    <td>
                                        <button class="btn-primary"
                                                @onclick="() => OpenInvoiceDetailsByIdAsync(invoiceRow.SalesInvoiceId)">View
                                            Details</button>
                                        </td>
                                    </tr>
                                }
                            }
                        else
                            {
                                <tr>
                                    <td colspan="5">No invoices found for this batch.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="modal-actions">
                    <button class="btn-secondary" @onclick="CloseBatchDetails">Close</button>
                </div>
            </div>
        </div>
    }

    <!-- INVOICE DETAILS MODAL (for Flat View) -->
    @if (showInvoiceDetailsModal)
    {
        <div class="modal-overlay" @onclick="CloseInvoiceDetails">
            <div class="modal-box batch-details-modal" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h4>Invoice Details: @selectedInvoiceCode</h4>
                </div>
                <div class="modal-body">
                    @if (selectedInvoiceDetails != null)
                    {
                        <!-- Invoice Header (Read-only form) -->
                        <div class="form-grid">
                            <div class="form-group">
                                <label>Invoice Date</label>
                                <input type="date" value="@selectedInvoiceDetails.InvoiceDate.ToString("yyyy-MM-dd")" disabled />
                            </div>
                            <div class="form-group">
                                <label>Order Date</label>
                                <input type="date" value="@selectedInvoiceDetails.OrderDate.ToString("yyyy-MM-dd")" disabled />
                            </div>
                            <div class="form-group">
                                <label>Order Type</label>
                                <input value="@selectedInvoiceDetails.OrderType" disabled />
                            </div>
                            <div class="form-group">
                                <label>Customer Name</label>
                                <input value="@selectedInvoiceDetails.CustomerName" disabled />
                            </div>
                            <div class="form-group">
                                <label>Customer Branch</label>
                                <input value="@selectedInvoiceDetails.CustomerBranch" disabled />
                            </div>
                            <div class="form-group">
                                <label>Address</label>
                                <input value="@selectedInvoiceDetails.Address" disabled />
                            </div>
                            <div class="form-group">
                                <label>Created Date</label>
                                <input value="@selectedInvoiceDetails.CreatedDate.ToString("yyyy-MM-dd HH:mm")" disabled />
                            </div>
                        </div>
                    
                        <h5>Item Details</h5>
                        <table class="activity-table">
                            <thead>
                                <tr>
                                    <th>Item Code</th>
                                    <th>Item Name</th>
                                    <th>UOM</th>
                                    <th>Quantity</th>
                                    <th>Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (selectedInvoiceDetails.ItemDetails.Any())
                                {
                                    @foreach (var item in selectedInvoiceDetails.ItemDetails)
                                    {
                                        <tr>
                                            <td>@item.ItemCode</td>
                                            <td>@item.ItemName</td>
                                            <td>@item.UomName</td>
                                            <td>@item.Quantity</td>
                                            <td>@FormatHelper.FormatPrice(item.Price)</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5">No item details found.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p>No invoice details available.</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(deleteInvoiceErrorMessage))
                    {
                        <p style="color: red;">@deleteInvoiceErrorMessage</p>
                    }
                    <div class="modal-actions">
                        <button class="btn-primary" @onclick="EditInvoiceDetails">Edit</button>
                        <button class="btn-secondary" @onclick="ShowDeleteInvoiceConfirm">Delete</button>
                        <button class="btn-secondary" @onclick="CloseInvoiceDetails">Close</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (showDeleteInvoiceConfirmModal)
    {
        <ConfirmModal Show="showDeleteInvoiceConfirmModal" Title="Delete Invoice"
                      Message="@($"Are you sure you want to delete invoice {selectedInvoiceCode}?")" OnYes="ConfirmDeleteInvoiceAsync"
                      OnNo="CancelDeleteInvoice" />
    }

<ConfirmModal Show="showErrorModal" Title="Error" ErrorMessage="@deleteInvoiceErrorMessage" ShowError="true"
              OnErrorConfirm="CloseErrorModal" />


@code {
    private int userid = 11; // Placeholder for user ID, to be replaced with actual user context
    private string UserFullName = string.Empty;

    private List<SubDistributor> subdList = new();
    private List<HomeSalesInvoiceBatchRow> batchRows = new();
    private List<HomeSalesInvoiceFlatRow> flatRows = new();
    private string currentViewMode = "batch"; // "batch" or "flat"
    private string selectedSubdNameFilter = string.Empty;
    private DateOnly? selectedDateFilter;
    private string sortByFilter = "date";
    
    // Batch View Modal
    private bool showBatchDetailsModal;
    private string selectedBatchId = string.Empty;
    private List<HomeSalesInvoiceBatchInvoiceRow> selectedBatchInvoices = new();
    private int selectedBatchSubDistributorId;
    private DateOnly selectedBatchCreatedDate;
    private int selectedBatchFirstInvoiceId;
    private int selectedBatchLastInvoiceId;
    
    // Flat View Modal
    private bool showInvoiceDetailsModal;
    private string selectedInvoiceCode = string.Empty;
    private HomeSalesInvoiceDetailRow? selectedInvoiceDetails;
    private bool showDeleteInvoiceConfirmModal;
    private string? deleteInvoiceErrorMessage;
    private bool showErrorModal = false;

    private IEnumerable<HomeSalesInvoiceBatchRow> FilteredBatchRows
    {
        get
        {
            var query = batchRows.AsEnumerable();
            
            // Filter by SubDistributor
            if (!string.IsNullOrWhiteSpace(selectedSubdNameFilter))
            {
                query = query.Where(r => r.SubdName.Contains(selectedSubdNameFilter, StringComparison.OrdinalIgnoreCase));
            }
            
            // Filter by Date
            if (selectedDateFilter.HasValue)
            {
                query = query.Where(r => r.BatchCreatedDate == selectedDateFilter.Value);
            }
            
            // Sort
            query = sortByFilter switch
            {
                "subd" => query.OrderBy(r => r.SubdCode).ThenByDescending(r => r.CreatedDate),
                _ => query.OrderByDescending(r => r.CreatedDate).ThenByDescending(r => r.LastSalesInvoiceId)
            };
            
            return query;
        }
    }

    private IEnumerable<HomeSalesInvoiceFlatRow> FilteredFlatRows
    {
        get
        {
            var query = flatRows.AsEnumerable();
            
            // Filter by SubDistributor
            if (!string.IsNullOrWhiteSpace(selectedSubdNameFilter))
            {
                query = query.Where(r => r.SubdName.Contains(selectedSubdNameFilter, StringComparison.OrdinalIgnoreCase));
            }
            
            // Filter by Date
            if (selectedDateFilter.HasValue)
            {
                query = query.Where(r => r.SalesInvoiceDate == selectedDateFilter.Value);
            }
            
            // Sort
            query = sortByFilter switch
            {
                "subd" => query.OrderBy(r => r.SubdName).ThenByDescending(r => r.SalesInvoiceDate),
                _ => query.OrderByDescending(r => r.SalesInvoiceDate)
            };
            
            return query;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        userContext.UserId = userid;

        var user = await homeService.GetUserAsync(userid);
        if (user != null)
        {
            UserFullName = user.FullName;
        }

        subdList = await homeService.GetSubDistributorsAsync(userid);
        batchRows = await homeService.GetSalesInvoiceBatchRowsAsync(userid);
        flatRows = await homeService.GetSalesInvoiceFlatRowsAsync(userid);
    }

    void InputSalesInvoice(int subDistributorId)
    {
        Navigation.NavigateTo($"/salesinvoice/{subDistributorId}?uid={userid}");
    }

    void GoToMapItems()
    {
        Navigation.NavigateTo($"/mapitem?uid={userid}");
    }

    void SetBatchMode()
    {
        currentViewMode = "batch";
    }

    void SetFlatMode()
    {
        currentViewMode = "flat";
    }

    void ToggleViewMode()
    {
        currentViewMode = currentViewMode == "batch" ? "flat" : "batch";
    }

    // Batch View Methods
    async Task OpenBatchDetailsAsync(HomeSalesInvoiceBatchRow row)
    {
        selectedBatchId = row.BatchId;
        selectedBatchSubDistributorId = row.SubDistributorId;
        selectedBatchCreatedDate = row.BatchCreatedDate;
        selectedBatchFirstInvoiceId = row.FirstSalesInvoiceId;
        selectedBatchLastInvoiceId = row.LastSalesInvoiceId;
        selectedBatchInvoices = await homeService.GetBatchInvoiceSummariesAsync(
            userid,
            row.SubDistributorId,
            row.BatchCreatedDate,
            row.FirstSalesInvoiceId,
            row.LastSalesInvoiceId);

        showBatchDetailsModal = true;
    }

    void CloseBatchDetails()
    {
        showBatchDetailsModal = false;
        selectedBatchId = string.Empty;
        selectedBatchInvoices = new();
        selectedBatchSubDistributorId = 0;
        selectedBatchCreatedDate = default;
        selectedBatchFirstInvoiceId = 0;
        selectedBatchLastInvoiceId = 0;
    }

    // Flat View Methods
    async Task OpenInvoiceDetailsAsync(HomeSalesInvoiceFlatRow row)
    {
        await OpenInvoiceDetailsByIdAsync(row.SalesInvoiceId, row.InvoiceCode);
    }

    async Task OpenInvoiceDetailsByIdAsync(int salesInvoiceId, string? invoiceCode = null)
    {
        selectedInvoiceCode = invoiceCode ?? string.Empty;
        deleteInvoiceErrorMessage = null;
        showDeleteInvoiceConfirmModal = false;

        selectedInvoiceDetails = await homeService.GetInvoiceDetailByIdAsync(
            userid,
            salesInvoiceId);

        if (selectedInvoiceDetails != null && string.IsNullOrWhiteSpace(selectedInvoiceCode))
        {
            selectedInvoiceCode = selectedInvoiceDetails.InvoiceNumber;
        }

        showInvoiceDetailsModal = true;
    }

    void CloseInvoiceDetails()
    {
        showInvoiceDetailsModal = false;
        showDeleteInvoiceConfirmModal = false;
        selectedInvoiceCode = string.Empty;
        selectedInvoiceDetails = null;
        deleteInvoiceErrorMessage = null;
    }

    void EditInvoiceDetails()
    {
        if (selectedInvoiceDetails != null)
        {
            Navigation.NavigateTo($"/salesinvoice/edit/{selectedInvoiceDetails.SalesInvoiceId}?uid={userid}");
        }
    }

    void ShowDeleteInvoiceConfirm()
    {
        if (selectedInvoiceDetails == null)
        {
            return;
        }

        deleteInvoiceErrorMessage = null;
        showDeleteInvoiceConfirmModal = true;
    }

    void CancelDeleteInvoice()
    {
        showDeleteInvoiceConfirmModal = false;
    }

    async Task ConfirmDeleteInvoiceAsync()
    {
        if (selectedInvoiceDetails == null)
        {
            return;
        }

        try
        {
            var deleted = await homeService.DeleteInvoiceByIdAsync(userid, selectedInvoiceDetails.SalesInvoiceId);
            if (!deleted)
            {
                deleteInvoiceErrorMessage = "Unable to delete invoice.";
                showErrorModal = true;
                return;
            }

            await ReloadRecentActivityAsync();

            if (showBatchDetailsModal && selectedBatchSubDistributorId > 0)
            {
                selectedBatchInvoices = await homeService.GetBatchInvoiceSummariesAsync(
                    userid,
                    selectedBatchSubDistributorId,
                    selectedBatchCreatedDate,
                    selectedBatchFirstInvoiceId,
                    selectedBatchLastInvoiceId);
            }

            showDeleteInvoiceConfirmModal = false;
            CloseInvoiceDetails();
        }
        catch
        {
            deleteInvoiceErrorMessage = "Unable to delete invoice due to a database error.";
            showErrorModal = true;
        }
    }

    private void CloseErrorModal()
    {
        showErrorModal = false;
        deleteInvoiceErrorMessage = null;
    }

    async Task ReloadRecentActivityAsync()
    {
        batchRows = await homeService.GetSalesInvoiceBatchRowsAsync(userid);
        flatRows = await homeService.GetSalesInvoiceFlatRowsAsync(userid);
    }
}