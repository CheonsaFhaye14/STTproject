@using Microsoft.AspNetCore.Components.Web
@using STTproject.Components.Helper
@using STTproject.Models
@using Microsoft.JSInterop

@implements IAsyncDisposable
@inject IJSRuntime JS

@if (ShowModal)
{
    <div class="modal-overlay" id="add-items-modal-overlay">
        <div class="modal-box">
            <div class="modal-header">
                <div class="invoice-header">
                    <h4>Add Invoice Items</h4>
                </div>
              
            </div>

            <div class="modal-body">
                <div class="form-group">
                    <label>@SalesInvoiceValidation.AddItem.Sku.Label<span class="required-asterisk"> *</span></label>
                    <input @ref="SkuCodeInput" @bind="NewSku" @bind:event="oninput" @onkeydown="HandleSkuKeyDown"
                           @onblur="HandleSkuBlur" />
                    @if (ShouldShowFieldError(SalesInvoiceValidation.AddItem.Sku.Key) &&
                                                        !string.IsNullOrWhiteSpace(GetFieldError(SalesInvoiceValidation.AddItem.Sku.Key)))
                    {
                        <span class="error-text">@GetFieldError(SalesInvoiceValidation.AddItem.Sku.Key)</span>
                    }
                </div>

                <div class="form-group">
                    <label>@SalesInvoiceValidation.AddItem.ItemName.Label<span class="required-asterisk"> *</span></label>
                    <select @ref="ItemNameSelect" value="@NewItem.ItemName" @onchange="OnItemNameChanged"
                            @onkeydown="HandleItemNameKeyDown" @onblur="HandleItemNameBlur">
                        <option value="">-- Select --</option>
                        @foreach (var subd in AvailableItems.Where(i => i.SubDistributorId ==
                                                                                                                                                                                                                    SelectedSubdistributorId).DistinctBy(i => i.ItemName))
                        {
                            <option value="@subd.ItemName">@subd.ItemName</option>
                        }
                    </select>
                    @if (ShouldShowFieldError(SalesInvoiceValidation.AddItem.ItemName.Key) &&
                                                        !string.IsNullOrWhiteSpace(GetFieldError(SalesInvoiceValidation.AddItem.ItemName.Key)))
                    {
                        <span class="error-text">@GetFieldError(SalesInvoiceValidation.AddItem.ItemName.Key)</span>
                    }
                </div>

                <div class="form-group">
                    <label>@SalesInvoiceValidation.AddItem.Uom.Label<span class="required-asterisk"> *</span></label>
                    <select @ref="UomSelect" value="@NewItem.ItemsUomId" @onchange="OnUomChanged"
                            disabled="@(CurrentSubdItem == null)" @onkeydown="HandleUomKeyDown" @onblur="HandleUomBlur">
                        <option value="0">-- Select --</option>
                        @if (CurrentSubdItem != null)
                        {
                            @foreach (var uom in AvailableUoms.Where(u => u.CompanyItemId == CurrentSubdItem.CompanyItemId))
                            {
                                <option value="@uom.ItemsUomId">@uom.UomName</option>
                            }
                        }
                    </select>
                    @if (ShouldShowFieldError(SalesInvoiceValidation.AddItem.Uom.Key) &&
                                                        !string.IsNullOrWhiteSpace(GetFieldError(SalesInvoiceValidation.AddItem.Uom.Key)))
                    {
                        <span class="error-text">@GetFieldError(SalesInvoiceValidation.AddItem.Uom.Key)</span>
                    }
                </div>

                <div class="form-group">
                    <label>@SalesInvoiceValidation.AddItem.Quantity.Label<span class="required-asterisk"> *</span></label>
                    <input @ref="QuantityInput" type="number" min="1" value="@NewItem.Quantity"
                           disabled="@(CurrentSubdItem == null)" onbeforeinput="if (event.data && (event.data.includes('-') 
                    )) event.preventDefault();" @oninput="OnQuantityInput" @onkeydown="HandleQuantityKeyDown"
                              @onblur="HandleQuantityBlur" />
                          @if (ShouldShowFieldError(SalesInvoiceValidation.AddItem.Quantity.Key) &&
                                                        !string.IsNullOrWhiteSpace(GetFieldError(SalesInvoiceValidation.AddItem.Quantity.Key)))
                    {
                        <span class="error-text">@GetFieldError(SalesInvoiceValidation.AddItem.Quantity.Key)</span>
                    }
                </div>

                <div class="form-group">
                    <label>Normal Price</label>
                    <input value="@GetNormalPriceDisplay()" disabled />
                </div>

                <div class="modal-actions">
                    <button type="button" class="btn-primary" @onclick="AddItemToQueue"
                            disabled="@(CurrentSubdItem == null || NewItem.ItemsUomId == 0 || !HeaderIsSaved)">
                        Add</button>
                        <button type="button" class="btn-secondary" @onclick="CancelModal">Cancel</button>
                        <button type="button" class="btn-primary" @onclick="SaveModal" disabled="@(!modalItems.Any())">
                            Save items</button>
                        </div>

                        <div class="modal-help">Press Enter after typing quantity to add the item quickly.</div>

                        @if (modalItems.Any())
                        {
                            <div class="modal-queue">
                                <h5>Queued items</h5>
                                <table>
                                    <thead>
                                        <tr>
                                            <th>SKU</th>
                                            <th>Name</th>
                                            <th>UOM</th>
                                            <th>Qty</th>
                                            <th>Line Amount</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var queuedItem in modalItems)
                                        {
                                            <tr>
                                                <td>@queuedItem.ItemCode</td>
                                                <td>@queuedItem.ItemName</td>
                                                <td>@(AvailableUoms.FirstOrDefault(u => u.ItemsUomId == queuedItem.ItemsUomId)?.UomName)
                                                </td>
                                                <td>@queuedItem.Quantity</td>
                                                <td>@FormatHelper.FormatPrice(@queuedItem.Amount)</td>
                                                <td><button type="button" class="btn remove-btn"
                                                                @onclick="() => RemoveQueuedItem(queuedItem)">Remove</button></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

@code {
    private ElementReference SkuCodeInput;
    private ElementReference ItemNameSelect;
    private ElementReference UomSelect;
    private ElementReference QuantityInput;
    private IJSObjectReference? jsModule;
    private bool ShowValidationErrors;
    private bool skipNextSkuBlurValidation;
    private HashSet<string> TouchedFieldKeys { get; set; } = new();
    private Dictionary<string, string> ValidationErrors { get; set; } = new();

    [Parameter] public bool ShowModal { get; set; }
    [Parameter] public EventCallback<bool> ShowModalChanged { get; set; }
    [Parameter] public EventCallback OnCancelModal { get; set; }
    [Parameter] public EventCallback<List<InputItemModel>> OnSaveModalItems { get; set; }

    [Parameter] public List<InputItemModel> Items { get; set; } = new();
    [Parameter] public EventCallback<List<InputItemModel>> ItemsChanged { get; set; }
    [Parameter] public List<SubdItem> AvailableItems { get; set; } = new();
    [Parameter] public List<ItemsUom> AvailableUoms { get; set; } = new();
    [Parameter] public int SelectedSubdistributorId { get; set; }
    [Parameter] public bool HeaderIsSaved { get; set; } = false;
    
    // Error handling state
    private string ErrorMessage = string.Empty;
    private string ErrorField = string.Empty;
    private async Task ValidateAndSave()
    {
        ErrorMessage = string.Empty;
        ErrorField = string.Empty;

        if (string.IsNullOrWhiteSpace(NewSku))
        {
            ErrorField = "NewSku";
            ErrorMessage = "SKU is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(NewItem.ItemName))
        {
            ErrorField = "ItemName";
            ErrorMessage = "Item Name is required.";
            return;
        }
    }

    private bool _wasModalShown;


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "/js/salesinvoice.js");
        }

        if (ShowModal && !_wasModalShown)
        {
            _wasModalShown = true;
            try
            {
                await SkuCodeInput.FocusAsync();
            }
            catch { }
        }
        else if (!ShowModal && _wasModalShown)
        {
            _wasModalShown = false;
        }
    }

    private List<InputItemModel> modalItems = new();
    public InputItemModel NewItem { get; set; } = CreateNewItem();
    private SubdItem? CurrentSubdItem { get; set; }
    private ItemsUom? CurrentUom { get; set; }
    private string SelectedUOM { get; set; } = string.Empty;

    private string NewSku
    {
        get => NewItem.ItemCode;
        set => OnSkuChanged(value);
    }

    private void OnSkuChanged(string sku)
    {
        NewItem.ItemCode = sku;

        var selected = AvailableItems
            .FirstOrDefault(i => i.SubdItemCode.Equals(sku, StringComparison.OrdinalIgnoreCase) && i.SubDistributorId ==
SelectedSubdistributorId);

        if (selected != null)
        {
            CurrentSubdItem = selected;
            NewItem.SubdItemId = selected.SubdItemId;
            NewItem.ItemName = selected.ItemName;
            NewItem.ItemsUomId = 0;
            CurrentUom = null;
        }
        else
        {
            CurrentSubdItem = null;
            NewItem.SubdItemId = 0;
            NewItem.ItemName = string.Empty;
            NewItem.ItemsUomId = 0;
            CurrentUom = null;
        }

        RevalidateIfNeeded();
    }

    private void OnItemNameChanged(ChangeEventArgs e)
    {
        var itemName = e.Value?.ToString();
        NewItem.ItemName = itemName ?? string.Empty;

        var selected = AvailableItems
            .FirstOrDefault(i => i.ItemName.Equals(itemName, StringComparison.OrdinalIgnoreCase) && i.SubDistributorId ==
SelectedSubdistributorId);

        if (selected != null)
        {
            NewItem.ItemCode = selected.SubdItemCode; // Auto-fill SKU
            CurrentSubdItem = selected;
            NewItem.SubdItemId = selected.SubdItemId;
            NewItem.ItemsUomId = 0;
            CurrentUom = null;
        }
        else
        {
            NewItem.ItemCode = string.Empty;
            CurrentSubdItem = null;
            NewItem.SubdItemId = 0;
            NewItem.ItemsUomId = 0;
            CurrentUom = null;
        }

        RevalidateIfNeeded();
    }

    private void OnUomChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int uomId))
        {
            NewItem.ItemsUomId = uomId;
            CurrentUom = AvailableUoms.FirstOrDefault(u => u.ItemsUomId == uomId);
        }

        RevalidateIfNeeded();
    }

    private void OnQuantityInput(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var quantity))
        {
            NewItem.Quantity = 0;
            RevalidateIfNeeded();
            return;
        }

        NewItem.Quantity = quantity;
        RevalidateIfNeeded();
    }

    private async Task AddItemToQueue()
    {
        ShowValidationErrors = true;
        ValidateDraft();

        if (ValidationErrors.Any())
        {
            return;
        }

        var selectedSubdItem = CurrentSubdItem!;
        var lineTotalPrice = NewItem.Quantity * selectedSubdItem.Price;

        var existingItem = modalItems.FirstOrDefault(item =>
            item.SubdItemId == NewItem.SubdItemId &&
            item.ItemsUomId == NewItem.ItemsUomId &&
            item.ItemCode.Equals(NewItem.ItemCode, StringComparison.OrdinalIgnoreCase) &&
            item.ItemName.Equals(NewItem.ItemName, StringComparison.OrdinalIgnoreCase));

        if (existingItem != null)
        {
            existingItem.Quantity += NewItem.Quantity;
            existingItem.Amount += lineTotalPrice;
        }
        else
        {
            modalItems.Add(new InputItemModel
            {
                ItemCode = NewItem.ItemCode,
                ItemName = NewItem.ItemName,
                SubdItemId = NewItem.SubdItemId,
                ItemsUomId = NewItem.ItemsUomId,
                Quantity = NewItem.Quantity,
                Amount = lineTotalPrice // Amount based on rules
            });
        }

        ResetNewItem();
    }

    private async Task SaveModal()
    {
        if (!modalItems.Any())
        {
            return;
        }

        if (OnSaveModalItems.HasDelegate)
        {
            await OnSaveModalItems.InvokeAsync(modalItems.ToList());
        }

        modalItems.Clear();
        await CloseModal();
    }

    public async Task SaveFromShortcutAsync()
    {
        await SaveModal();
    }

    private async Task CancelModal()
    {
        modalItems.Clear();

        if (OnCancelModal.HasDelegate)
        {
            await OnCancelModal.InvokeAsync();
        }

        await CloseModal();
    }

    private async Task CloseModal()
    {
        if (ShowModalChanged.HasDelegate)
        {
            await ShowModalChanged.InvokeAsync(false);
        }
    }

    private void RemoveQueuedItem(InputItemModel item)
    {
        modalItems.Remove(item);
    }

    private void ResetNewItem()
    {
        NewItem = CreateNewItem();
        NewItem.Quantity = 1;
        CurrentSubdItem = null;
        CurrentUom = null;
        ShowValidationErrors = false;
        TouchedFieldKeys.Clear();
        ValidationErrors.Clear();
    }

    private static InputItemModel CreateNewItem()
    {
        return new InputItemModel
        {
            Quantity = 1
        };
    }

    private async Task HandleSkuKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            if (string.IsNullOrWhiteSpace(NewItem.ItemCode))
            {
                ValidationErrors.Remove(SalesInvoiceValidation.AddItem.Sku.Key);
                ValidationErrors.Remove(SalesInvoiceValidation.AddItem.ItemName.Key);
                skipNextSkuBlurValidation = true;

                await Task.Delay(10);
                await ItemNameSelect.FocusAsync();
                return;
            }

            MarkFieldTouched(SalesInvoiceValidation.AddItem.Sku.Key);
            ValidateDraft();
            await Task.Delay(10); // buffer slightly to allow bindings
            if (CurrentSubdItem != null)
            {
                await UomSelect.FocusAsync();
            }
            else
            {
                await ItemNameSelect.FocusAsync();
            }
        }
    }

    private async Task HandleItemNameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            MarkFieldTouched(SalesInvoiceValidation.AddItem.ItemName.Key);
            ValidateDraft();

            if (string.IsNullOrWhiteSpace(NewItem.ItemName))
            {
                await OpenSelectDropdownAsync(ItemNameSelect);
                return;
            }

            await Task.Delay(10);
            await UomSelect.FocusAsync();
        }
    }

    private async Task HandleUomKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            MarkFieldTouched(SalesInvoiceValidation.AddItem.Uom.Key);
            ValidateDraft();

            if (NewItem.ItemsUomId == 0)
            {
                await OpenSelectDropdownAsync(UomSelect);
                return;
            }

            await Task.Delay(10);
            await QuantityInput.FocusAsync();
        }
    }

    private async Task OpenSelectDropdownAsync(ElementReference selectRef)
    {
        if (jsModule != null)
        {
            await jsModule.InvokeVoidAsync("openSelectDropdown", selectRef);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (jsModule != null)
        {
            await jsModule.DisposeAsync();
            jsModule = null;
        }
    }

    private async Task HandleQuantityKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            MarkFieldTouched(SalesInvoiceValidation.AddItem.Quantity.Key);
            ValidateDraft();
            await AddItemToQueue();
            await Task.Delay(10);
            await SkuCodeInput.FocusAsync();
        }
    }

    private Task HandleSkuBlur(FocusEventArgs _)
    {
        if (skipNextSkuBlurValidation)
        {
            skipNextSkuBlurValidation = false;
            return Task.CompletedTask;
        }

        MarkFieldTouched(SalesInvoiceValidation.AddItem.Sku.Key);
        ValidateDraft();
        return Task.CompletedTask;
    }

    private Task HandleItemNameBlur(FocusEventArgs _)
    {
        MarkFieldTouched(SalesInvoiceValidation.AddItem.ItemName.Key);
        ValidateDraft();
        return Task.CompletedTask;
    }

    private Task HandleUomBlur(FocusEventArgs _)
    {
        if (CurrentSubdItem is null)
        {
            return Task.CompletedTask;
        }

        MarkFieldTouched(SalesInvoiceValidation.AddItem.Uom.Key);
        ValidateDraft();
        return Task.CompletedTask;
    }

    private Task HandleQuantityBlur(FocusEventArgs _)
    {
        if (CurrentSubdItem is null)
        {
            return Task.CompletedTask;
        }

        MarkFieldTouched(SalesInvoiceValidation.AddItem.Quantity.Key);
        ValidateDraft();
        return Task.CompletedTask;
    }

    private string GetNormalPriceDisplay()
    {
        return CurrentSubdItem is null
            ? string.Empty
            : FormatHelper.FormatPrice(CurrentSubdItem.Price);
    }

    private void ValidateDraft()
    {
        ValidationErrors = SalesInvoiceValidation.ValidateAddItemDraft(NewItem, CurrentSubdItem, CurrentUom);
    }

    private void RevalidateIfNeeded()
    {
        if (ShowValidationErrors || TouchedFieldKeys.Any())
        {
            ValidateDraft();
        }
    }

    private bool ShouldShowFieldError(string fieldKey)
    {
        return ShowValidationErrors || TouchedFieldKeys.Contains(fieldKey);
    }

    private void MarkFieldTouched(string fieldKey)
    {
        TouchedFieldKeys.Add(fieldKey);
    }

    private string GetFieldError(string fieldKey)
    {
        return ValidationErrors.TryGetValue(fieldKey, out var message) ? message : string.Empty;
    }
}
