@using Microsoft.AspNetCore.Components.Web
@using STTproject.Models

@if (ShowModal)
{
    <div class="modal-overlay">
        <div class="modal-box">
            <div class="modal-header">
                <h4>Add Invoice Items</h4>
                <button type="button" class="close-btn" @onclick="CancelModal">×</button>
            </div>

            <div class="modal-body">
                <div class="modal-field">
                    <label>SKU Code</label>
                    <input @bind="NewSku" @onkeydown="HandleEnterKey" />
                </div>

                <div class="modal-field">
                    <label>Description</label>
                    <input @bind="NewItem.Description" disabled />
                </div>

                <div class="modal-field">
                    <label>Unit of Measure</label>
                    <select @bind="SelectedUOM" disabled="@(CurrentSubdItem == null)">
                        <option value="">-- Select --</option>
                        @if (CurrentSubdItem != null)
                        {
                            <option value="@CurrentSubdItem.UOM">@CurrentSubdItem.UOM</option>
                            <option value="per piece">per piece</option>
                        }
                    </select>
                </div>

                <div class="modal-field">
                    <label>Quantity</label>
                    <input type="number" @bind="NewItem.Quantity" disabled="@(CurrentSubdItem == null)"
                           @onkeydown="HandleEnterKey" />
                </div>

                <div class="modal-actions">
                    <button type="button" class="btn-primary" @onclick="AddItemToQueue"
                            disabled="@(CurrentSubdItem == null || string.IsNullOrWhiteSpace(SelectedUOM) || NewItem.Quantity <= 0 || !HeaderIsSaved)">Add
                        to list</button>
                        <button type="button" class="btn-secondary" @onclick="CancelModal">Cancel</button>
                        <button type="button" class="btn-primary" @onclick="SaveModal" disabled="@(!modalItems.Any())">Save
                            items</button>
                        </div>

                        <div class="modal-help">Press Enter after typing quantity to add the item quickly.</div>

                        @if (modalItems.Any())
                        {
                            <div class="modal-queue">
                                <h5>Queued items</h5>
                                <table>
                                    <thead>
                                        <tr>
                                            <th>SKU</th>
                                            <th>Description</th>
                                            <th>UOM</th>
                                            <th>Qty</th>
                                            <th>Price</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var queuedItem in modalItems)
                                        {
                                            <tr>
                                                <td>@queuedItem.ItemCode</td>
                                                <td>@queuedItem.Description</td>
                                                <td>@queuedItem.Unit</td>
                                                <td>@queuedItem.Quantity</td>
                                                <td>@GetUnitPrice(queuedItem)</td>
                                                <td><button type="button" class="btn remove-btn"
                                                                @onclick="() => RemoveQueuedItem(queuedItem)">Remove</button></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

@code {
    [Parameter] public bool ShowModal { get; set; }
    [Parameter] public EventCallback<bool> ShowModalChanged { get; set; }
    [Parameter] public EventCallback OnCancelModal { get; set; }
    [Parameter] public EventCallback<List<InputItemModel>> OnSaveModalItems { get; set; }

    [Parameter] public List<InputItemModel> Items { get; set; } = new();
    [Parameter] public EventCallback<List<InputItemModel>> ItemsChanged { get; set; }
    [Parameter] public List<SubdItem> AvailableItems { get; set; } = new();
    [Parameter] public int SelectedSubdistributorId { get; set; }
    [Parameter] public bool HeaderIsSaved { get; set; } = false;

    private List<InputItemModel> modalItems = new();
    public InputItemModel NewItem { get; set; } = new();
    private SubdItem? CurrentSubdItem { get; set; }
    private string SelectedUOM { get; set; } = string.Empty;

    private string NewSku
    {
        get => NewItem.ItemCode;
        set => OnSkuChanged(value);
    }

    private void OnSkuChanged(string sku)
    {
        NewItem.ItemCode = sku;

        var selected = AvailableItems
            .FirstOrDefault(i => i.SubdItemCode.Equals(sku, StringComparison.OrdinalIgnoreCase));

        if (selected != null && selected.SubDistributorId == SelectedSubdistributorId)
        {
            CurrentSubdItem = selected;
            NewItem.SubdItemId = selected.SubdItemId;
            NewItem.Price = selected.Price;
            NewItem.PricePerPiece = selected.PricePerPiece;
            SelectedUOM = string.Empty;
            GenerateDescription();
        }
        else
        {
            CurrentSubdItem = null;
            NewItem.SubdItemId = 0;
            NewItem.Description = string.Empty;
            SelectedUOM = string.Empty;
            NewItem.Price = 0;
            NewItem.PricePerPiece = 0;
        }
    }

    private void GenerateDescription()
    {
        if (CurrentSubdItem != null)
        {
            NewItem.Description = $"{CurrentSubdItem.ItemName} {CurrentSubdItem.UnitContent} x{CurrentSubdItem.QuantityPerPiece} {CurrentSubdItem.UOM}";
        }
    }

    private async Task AddItemToQueue()
    {
        if (CurrentSubdItem == null || string.IsNullOrWhiteSpace(SelectedUOM) || NewItem.Quantity <= 0)
        {
            return;
        }

        modalItems.Add(new InputItemModel
        {
            SubdItemId = NewItem.SubdItemId,
            ItemCode = NewItem.ItemCode,
            Description = NewItem.Description,
            Unit = SelectedUOM,
            Quantity = NewItem.Quantity,
            Price = NewItem.Price,
            PricePerPiece = NewItem.PricePerPiece
        });

        ResetNewItem();
    }

    private async Task SaveModal()
    {
        if (!modalItems.Any())
        {
            return;
        }

        if (OnSaveModalItems.HasDelegate)
        {
            await OnSaveModalItems.InvokeAsync(modalItems.ToList());
        }

        if (ItemsChanged.HasDelegate)
        {
            var updatedItems = Items.ToList();
            updatedItems.AddRange(modalItems);
            await ItemsChanged.InvokeAsync(updatedItems);
        }

        modalItems.Clear();
        await CloseModal();
    }

    private async Task CancelModal()
    {
        modalItems.Clear();

        if (OnCancelModal.HasDelegate)
        {
            await OnCancelModal.InvokeAsync();
        }

        await CloseModal();
    }

    private async Task CloseModal()
    {
        if (ShowModalChanged.HasDelegate)
        {
            await ShowModalChanged.InvokeAsync(false);
        }
    }

    private void RemoveQueuedItem(InputItemModel item)
    {
        modalItems.Remove(item);
    }

    private void ResetNewItem()
    {
        NewItem = new InputItemModel();
        CurrentSubdItem = null;
        SelectedUOM = string.Empty;
    }

    private int GetUnitPrice(InputItemModel item)
    {
        if (item.Unit.Equals("per piece", StringComparison.OrdinalIgnoreCase))
        {
            var subdItem = AvailableItems.FirstOrDefault(i => i.SubdItemId == item.SubdItemId);
            return subdItem?.PricePerPiece ?? item.Price;
        }

        return item.Price;
    }

    private Task HandleEnterKey(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            return AddItemToQueue();
        }

        return Task.CompletedTask;
    }
}
