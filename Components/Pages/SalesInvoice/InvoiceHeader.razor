@using STTproject.Models

<div class="top-card">
    <div class="form-grid">
        <div class="form-group">
            <label>Sales Invoice Number</label>
            <input @ref="invoiceNumberInput" @bind="Invoice.InvoiceNumber" disabled="@IsSaved" />
            @if (!string.IsNullOrWhiteSpace(ErrorMessage) && ErrorField == "InvoiceNumber")
            {
                <span class="error-text">@ErrorMessage</span>
            }
        </div>

        <div class="form-group">
            <label>Sales Invoice Date</label>
            <input type="date" @bind="DateValue" disabled="@IsSaved" placeholder="MM/DD/YYYY" />
            @if (!string.IsNullOrWhiteSpace(ErrorMessage) && ErrorField == "InvoiceDate")
            {
                <span class="error-text">@ErrorMessage</span>
            }
        </div>
        <div class="form-group">
            <label>Order Type</label>
            <select @bind="Invoice.OrderType" disabled="@IsSaved">
                <option value="">-- Select --</option>
                <option value="invoice">Invoice</option>
                <option value="credit">Credit</option>
            </select>
            @if (!string.IsNullOrWhiteSpace(ErrorMessage) && ErrorField == "OrderType")
            {
                <span class="error-text">@ErrorMessage</span>
            }
        </div>
        <div class="form-group">
            <label>Customer Code</label>
            <input @bind="Invoice.CustomerCode" @bind:event="onchange" @bind:after="HandleCustomerCodeChanged" disabled="@IsSaved" />
            @if (!string.IsNullOrWhiteSpace(ErrorMessage) && ErrorField == "CustomerCode")
            {
                <span class="error-text">@ErrorMessage</span>
            }
        </div>
        <div class="form-group">
            <label>Customer Name</label>
            <input @bind="Invoice.CustomerName" disabled />
            @if (!string.IsNullOrWhiteSpace(ErrorMessage) && ErrorField == "CustomerId")
            {
                <span class="error-text">@ErrorMessage</span>
            }
        </div>



        <div class="form-group">
            <label>Customer Branch</label>
            @if (FilteredCustomerBranches.Any())
            {
                <select @bind="Invoice.CustomerBranchId" @bind:after="HandleBranchChanged" disabled="@IsSaved">
                    <option value="0">-- Select branch --</option>
                    @foreach (var branch in FilteredCustomerBranches)
                    {
                        <option value="@branch.CustomerBranchId">@branch.BranchName - @branch.City</option>
                    }
                </select>
                @if (!string.IsNullOrWhiteSpace(ErrorMessage) && ErrorField == "CustomerBranchId")
                {
                    <span class="error-text">@ErrorMessage</span>
                }
            }
            else
            {
                <input value="No branches available" disabled />
            }
        </div>


        <div class="form-group">
            <label>Customer Type</label>
            <input @bind="Invoice.CustomerType" disabled />
            @if (!string.IsNullOrWhiteSpace(ErrorMessage) && ErrorField == "CustomerType")
            {
                <span class="error-text">@ErrorMessage</span>
            }
        </div>
        
        <div class="form-group">
            <label>Customer Address</label>
            <input @bind="Invoice.CustomerAddress" disabled />
            @if (!string.IsNullOrWhiteSpace(ErrorMessage) && ErrorField == "CustomerAddress")
            {
                <span class="error-text">@ErrorMessage</span>
            }
        </div>
    </div>

    @if (!IsSaved)
    {
        <button class="btn-primary" @onclick="ValidateAndSave">Save</button>
    }
    else
    {
        <button class="btn-primary" @onclick="OnEditClick">Edit</button>
    }


</div>

@code {
    [Parameter] public InputInvoiceModel Invoice { get; set; } = new();
    [Parameter] public bool IsSaved { get; set; }
    [Parameter] public EventCallback OnSaveClick { get; set; }
    [Parameter] public EventCallback OnEditClick { get; set; }
    private DateOnly? DateValue
    {
        get => Invoice.InvoiceDate != default(DateOnly) ? Invoice.InvoiceDate : null;
        set
        {
            Invoice.InvoiceDate = value ?? default;
        }
    }

    private ElementReference invoiceNumberInput;

    // Error handling state
    private string ErrorMessage = string.Empty;
    private string ErrorField = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await invoiceNumberInput.FocusAsync();
        }
    }

    private async Task ValidateAndSave()
    {
        ErrorMessage = string.Empty;
        ErrorField = string.Empty;

        if (string.IsNullOrWhiteSpace(Invoice.InvoiceNumber))
        {
            ErrorField = "InvoiceNumber";
            ErrorMessage = "Invoice number is required.";
            return;
        }

        if (Invoice.InvoiceDate == default)
        {
            ErrorField = "InvoiceDate";
            ErrorMessage = "Invoice date is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(Invoice.OrderType))
        {
            ErrorField = "OrderType";
            ErrorMessage = "Order type is required.";
            return;
        }

        if (Invoice.CustomerId <= 0)
        {
            ErrorField = "CustomerId";
            ErrorMessage = "Customer is required.";
            return;
        }

        if (FilteredCustomerBranches.Any() && Invoice.CustomerBranchId <= 0)
        {
            ErrorField = "CustomerBranchId";
            ErrorMessage = "Customer branch is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(Invoice.CustomerType))
        {
            ErrorField = "CustomerType";
            ErrorMessage = "Customer type is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(Invoice.CustomerName))
        {
            ErrorField = "CustomerName";
            ErrorMessage = "Customer name is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(Invoice.CustomerAddress))
        {
            ErrorField = "CustomerAddress";
            ErrorMessage = "Customer address is required.";
            return;
        }

        // ✅ If all checks pass, trigger parent save
        await OnSaveClick.InvokeAsync();

        // 👇 Mark as saved so Edit button appears
        IsSaved = true;
    }

    [Parameter] public List<Customer> Customers { get; set; } = new();
    [Parameter] public List<CustomerBranch> CustomerBranches { get; set; } = new();

    private List<CustomerBranch> FilteredCustomerBranches { get; set; } = new();

    protected override void OnParametersSet()
    {
        SyncCustomerState();
    }

    private Task HandleCustomerCodeChanged()
    {
        SyncCustomerState();
        return Task.CompletedTask;
    }

    private Task HandleBranchChanged()
    {
        ApplySelectedBranch(Invoice.CustomerBranchId);
        return Task.CompletedTask;
    }

    private void SyncCustomerState()
    {
        var selectedCustomer = Customers.FirstOrDefault(customer =>
            customer.CustomerCode.Equals(Invoice.CustomerCode, StringComparison.OrdinalIgnoreCase));

        if (selectedCustomer is null && Invoice.CustomerId > 0)
        {
            selectedCustomer = Customers.FirstOrDefault(customer => customer.CustomerId == Invoice.CustomerId);
        }

        if (selectedCustomer is null)
        {
            Invoice.CustomerId = 0;
            Invoice.CustomerName = string.Empty;
            Invoice.CustomerType = string.Empty;
            Invoice.CustomerAddress = string.Empty;
            Invoice.CustomerBranchId = 0;
            FilteredCustomerBranches = new List<CustomerBranch>();
            return;
        }

        Invoice.CustomerCode = selectedCustomer.CustomerCode;
        Invoice.CustomerId = selectedCustomer.CustomerId;
        Invoice.CustomerName = selectedCustomer.CustomerName;
        Invoice.CustomerType = selectedCustomer.CustomerType;

        FilteredCustomerBranches = CustomerBranches
            .Where(branch => branch.CustomerId == selectedCustomer.CustomerId)
            .OrderBy(branch => branch.BranchName)
            .ToList();

        if (FilteredCustomerBranches.Any())
        {
            if (Invoice.CustomerBranchId <= 0 || !FilteredCustomerBranches.Any(branch => branch.CustomerBranchId ==
Invoice.CustomerBranchId))
            {
                Invoice.CustomerBranchId = FilteredCustomerBranches[0].CustomerBranchId;
            }

            ApplySelectedBranch(Invoice.CustomerBranchId);
        }
        else
        {
            Invoice.CustomerBranchId = 0;
            Invoice.CustomerAddress = string.Empty;
        }
    }

    private void ApplySelectedBranch(int branchId)
    {
        var selectedBranch = FilteredCustomerBranches.FirstOrDefault(branch => branch.CustomerBranchId == branchId);

        if (selectedBranch is null)
        {
            Invoice.CustomerAddress = string.Empty;
            return;
        }

        Invoice.CustomerAddress = FormatBranchAddress(selectedBranch);
    }

    private static string FormatBranchAddress(CustomerBranch branch)
    {
        var parts = new List<string> { branch.AddressLine, branch.City, branch.Province };

        if (!string.IsNullOrWhiteSpace(branch.ZipCode))
        {
            parts.Add(branch.ZipCode);
        }

        return string.Join(", ", parts.Where(part => !string.IsNullOrWhiteSpace(part)));
    }

}

