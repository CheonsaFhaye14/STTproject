@page "/salesinvoice/{SubDistributorId:int}"

@using Microsoft.AspNetCore.Components

@using STTproject.Data
@using STTproject.Models

@inject AppDbContext db

@rendermode InteractiveServer

<TitleHeader
    Subdistributors="subdList"
    @bind-SelectedSubdId="invoice.SubdistributorId"
    OnSubdChanged="UpdateSubdDisplay" />

<div class="top-buttons">
    <button class="btn-primary">Download Template</button>
    <button class="btn-primary">Import</button>
</div>

@* invoice header *@
<div class="top-card">
    <div class="form-grid">
        <div class="form-group">
            <label>Sales Invoice Number</label>
            <input @ref="invoiceNumberInput" @bind="invoice.InvoiceNumber" disabled="@isSaved" />
        </div>

        <div class="form-group">
            <label>Sales Invoice Date</label>
            <input type="date" @bind="invoice.InvoiceDate" disabled="@isSaved" />
        </div>

        <div class="form-group">
            <label>Order Type</label>
            <select @bind="invoice.OrderType" disabled="@isSaved">
                <option value="invoice">Invoice</option>
                <option value="credit">Credit</option>
            </select>
        </div>

        <div class="form-group">
            <label>Customer Code</label>
            <input @bind="invoice.CustomerCode" @bind:event="oninput" @bind:after="CheckCustomer" disabled="@isSaved" />
        </div>

        <div class="form-group">
            <label>Customer Type</label>
            <input @bind="invoice.CustomerType" disabled />
        </div>

        <div class="form-group">
            <label>Customer Name</label>
            <input @bind="invoice.CustomerName" disabled />
        </div>

        <div class="form-group">
            <label>Customer Address</label>
            <input @bind="invoice.CustomerAddress" disabled />
        </div>
    </div>


        <button class="btn-primary" @onclick="ShowConfirm">
            Save
        </button>

    @if (isSaved)
    {
        <button class="btn-primary" @onclick="EnableEdit">
            Edit
        </button>
    }

</div>

@if (showConfirmModal)
{
    <div class="modal-overlay">
        <div class="modal-box">
            <h4>Are you sure you want to save?</h4>

            <button class="btn-primary" @onclick="ConfirmSave">Yes</button>
            <button class="btn-primary" @onclick="CancelSave">No</button>
        </div>
    </div>
}

<!-- MAIN SECTION -->
<div class="main-grid">

    <!-- LEFT -->
    <div class="card">
        <div>
            <label>Item Code</label>
            <input @bind="newItem.ItemCode" />
        </div>

        <div>
            <label>Description</label>
            <input @bind="newItem.Description" />
        </div>

        <div>
            <label>Unit of Measure</label>
            <input @bind="newItem.Unit" />
        </div>

        <div>
            <label>Quantity</label>
            <input type="number" @bind="newItem.Quantity" />
        </div>

        <button class="btn add-btn" @onclick="AddItem">Add</button>
    </div>

    <!-- RIGHT -->
    <div class="card">
        <h4 class="center">INVOICE ITEMS</h4>

        <table>
            <thead>
                <tr>
                    <th>Item Code</th>
                    <th>Description</th>
                    <th>Unit</th>
                    <th>Qty</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in items)
                {
                    <tr>
                        <td>@item.ItemCode</td>
                        <td>@item.Description</td>
                        <td>@item.Unit</td>
                        <td>@item.Quantity</td>
                    </tr>
                }
            </tbody>
        </table>

        <button class="btn">Upload</button>
    </div>

</div>
@code {
    int currentInvoiceId = 0;
    void ShowConfirm()
    {
        showConfirmModal = true;
    }

    void CancelSave()
    {
        showConfirmModal = false;
    }

    async Task ConfirmSave()
    {
        showConfirmModal = false;

        // ❗ CHECK duplicate invoice number (except current one)
        var existingInvoice = db.SalesInvoices
            .FirstOrDefault(x => x.SalesInvoiceCode == invoice.InvoiceNumber);

        if (existingInvoice != null && existingInvoice.SalesInvoiceId != currentInvoiceId)
        {
            // stop saving
            Console.WriteLine("Duplicate invoice number!");
            return;
        }

        if (currentInvoiceId == 0)
        {
            // ✅ CREATE NEW
            var salesInvoice = new STTproject.Models.SalesInvoice
            {
                SalesInvoiceCode = invoice.InvoiceNumber,
                SalesInvoiceDate = invoice.InvoiceDate,
                OrderType = invoice.OrderType,
                CustomerId = invoice.CustomerId,
                SubDistributorId = invoice.SubdistributorId,

                Items = items.Select(i => new STTproject.Models.SalesInvoiceItem
                {
                    SubdItemId = i.SubdItemId
                }).ToList()
            };

            db.SalesInvoices.Add(salesInvoice);
            await db.SaveChangesAsync();

            currentInvoiceId = salesInvoice.SalesInvoiceId; // 👈 important
        }
        else
        {
            // ✅ UPDATE EXISTING
            var existing = db.SalesInvoices
                .FirstOrDefault(x => x.SalesInvoiceId == currentInvoiceId);

            if (existing != null)
            {
                existing.SalesInvoiceCode = invoice.InvoiceNumber;
                existing.SalesInvoiceDate = invoice.InvoiceDate;
                existing.OrderType = invoice.OrderType;
                existing.CustomerId = invoice.CustomerId;
                existing.SubDistributorId = invoice.SubdistributorId;

                await db.SaveChangesAsync();
            }
        }

        isSaved = true;
    }
    void EnableEdit()
    {
        isSaved = false; 
    }
    bool showConfirmModal = false;
    bool isSaved = false;

    private ElementReference invoiceNumberInput;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await invoiceNumberInput.FocusAsync();
        }
    }
   
    [Parameter]
    public int SubDistributorId { get; set; }

    SubDistributor? subd;

    SubdModel subdModel = new();
    InputInvoiceModel invoice = new();
    InputItemModel newItem = new();
    List<InputItemModel> items = new();

    List<SubDistributor> subdList = new();

    protected override void OnParametersSet()
    {
        subdList = db.SubDistributors.ToList();

        subd = subdList
            .FirstOrDefault(s => s.SubDistributorId == SubDistributorId);

        if (subd != null)
        {
            invoice.SubdistributorId = subd.SubDistributorId;
            UpdateSubdDisplay(subd);
        }
    }
    void CheckCustomer()
    {
        if (string.IsNullOrWhiteSpace(invoice.CustomerCode))
        {
            ClearCustomer();
            return;
        }

        var existing = db.Customers
            .FirstOrDefault(c => c.CustomerCode == invoice.CustomerCode);

        if (existing != null)
        {
            invoice.CustomerId = existing.CustomerId;
            invoice.CustomerType = existing.CustomerType;
            invoice.CustomerName = existing.CustomerName;
            invoice.CustomerAddress = existing.CustomerAddress;
        }
        else
        {
            ClearCustomer();
        }
    }
    void ClearCustomer()
    {
        invoice.CustomerId = 0;
        invoice.CustomerType = string.Empty;
        invoice.CustomerName = string.Empty;
        invoice.CustomerAddress = string.Empty;
    }

    async Task SaveInvoice()
    {

        var salesInvoice = new STTproject.Models.SalesInvoice
        {
            SalesInvoiceCode = invoice.InvoiceNumber,
            SalesInvoiceDate = invoice.InvoiceDate,
            OrderType = invoice.OrderType,

            CustomerId = invoice.CustomerId,
            SubDistributorId = invoice.SubdistributorId,

            Items = items.Select(i => new STTproject.Models.SalesInvoiceItem
            {
                SubdItemId = i.SubdItemId
            }).ToList()
        };
         
        db.SalesInvoices.Add(salesInvoice);
        await db.SaveChangesAsync();
    }

    
    void AddItem()
    {
        items.Add(new InputItemModel
        {
            ItemCode = newItem.ItemCode,
            Description = newItem.Description,
            Unit = newItem.Unit,
            Quantity = newItem.Quantity
        });

        newItem = new InputItemModel();
    }

    public class SubdModel
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
    }

    public class InputInvoiceModel
    {
        public string InvoiceNumber { get; set; } = string.Empty;
        public DateOnly InvoiceDate { get; set; }
        public string OrderType { get; set; } = string.Empty;
        public int CustomerId { get; set; }
        public string CustomerType { get; set; } = string.Empty;
        public string CustomerCode { get; set; } = string.Empty;
        public string CustomerName { get; set; } = string.Empty;
        public string CustomerAddress { get; set; } = string.Empty;
        public int SubdistributorId { get; set; }
    }

    public class InputItemModel
    {
        public int SubdItemId { get; set; }   
        public string ItemCode { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string Unit { get; set; } = string.Empty;
        public int Quantity { get; set; }
    }

    void OnSubdChange()
    {
        var selected = subdList
            .FirstOrDefault(s => s.SubDistributorId == invoice.SubdistributorId);

        if (selected != null)
        {
            UpdateSubdDisplay(selected);
        }
    }
   
    void UpdateSubdDisplay(SubDistributor s)
    {
        subdModel.Code = s.SubdCode;
        subdModel.Name = s.SubdName;

        invoice.SubdistributorId = s.SubDistributorId;
    }
}