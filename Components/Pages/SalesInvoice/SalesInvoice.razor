@page "/salesinvoice/{SubDistributorId:int}"

@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using STTproject.Data
@using STTproject.Models

@inject AppDbContext db
@inject IJSRuntime JS

@implements IAsyncDisposable

@rendermode InteractiveServer

<TitleHeader Subdistributors="subdList" @bind-SelectedSubdId="invoice.SubdistributorId"
             OnSubdChanged="UpdateSubdDisplay" IsSaved="isSaved" />

<div class="top-buttons">
    <button class="btn-primary">Download Template</button>
    <button class="btn-primary">Import</button>
</div>

<InvoiceHeader Invoice="invoice" IsSaved="isSaved" OnSaveClick="ShowConfirm" OnEditClick="EnableEdit"
               OnCustomerCheck="CheckCustomer" />

@if (showConfirmModal)
{
    <div class="modal-overlay">
        <div class="modal-box">
            <h4>Are you sure you want to save?</h4>

            <button class="btn-primary" @onclick="ConfirmSave">Yes</button>
            <button class="btn-primary" @onclick="CancelSave">No</button>
        </div>
    </div>
}

@if (isSaved)
{
    <div class="item-actions">
        <button class="btn-primary" @onclick="OpenAddItemsModal">Add Items</button>
        <span class="shortcut-hint">Press F3 to open the add-items modal</span>
    </div>
}

<InvoiceItems ShowModal="showAddItemsModal" OnSaveModalItems="OnModalItemsSaved" OnCancelModal="CloseAddItemsModal"
              Items="items" ItemsChanged="OnItemsChanged" AvailableItems="subdItems"
              SelectedSubdistributorId="invoice.SubdistributorId" HeaderIsSaved="isSaved" />

<InvoiceItemsTable Items="items" ItemsChanged="OnItemsChanged" AvailableItems="subdItems" />

@code {
    private bool showAddItemsModal = false;
    private IJSObjectReference? jsModule;
    private DotNetObjectReference<SalesInvoice>? objRef;

    void OnItemsChanged(List<InputItemModel> updatedItems)
    {
        items = updatedItems;
    }

    int currentInvoiceId = 0;
    void ShowConfirm()
    {
        if (!isSaved)
        {
            showConfirmModal = true;
        }
    }

    void CancelSave()
    {
        showConfirmModal = false;
    }

    async Task ConfirmSave()
    {
        showConfirmModal = false;

        var existingInvoice = db.SalesInvoices
            .FirstOrDefault(x => x.SalesInvoiceCode == invoice.InvoiceNumber);

        if (existingInvoice != null && existingInvoice.SalesInvoiceId != currentInvoiceId)
        {
            Console.WriteLine("Duplicate invoice number!");
            return;
        }

        if (currentInvoiceId == 0)
        {
            var salesInvoice = new STTproject.Models.SalesInvoice
            {
                SalesInvoiceCode = invoice.InvoiceNumber,
                SalesInvoiceDate = invoice.InvoiceDate,
                OrderType = invoice.OrderType,
                CustomerId = invoice.CustomerId,
                SubDistributorId = invoice.SubdistributorId,
                Items = items.Select(i => new STTproject.Models.SalesInvoiceItem
                {
                    SubdItemId = i.SubdItemId,
                    Quantity = i.Quantity,
                    Price = i.Price
                }).ToList()
            };

            db.SalesInvoices.Add(salesInvoice);
            await db.SaveChangesAsync();

            currentInvoiceId = salesInvoice.SalesInvoiceId;
        }
        else
        {
            var existing = db.SalesInvoices
                .FirstOrDefault(x => x.SalesInvoiceId == currentInvoiceId);

            if (existing != null)
            {
                existing.SalesInvoiceCode = invoice.InvoiceNumber;
                existing.SalesInvoiceDate = invoice.InvoiceDate;
                existing.OrderType = invoice.OrderType;
                existing.CustomerId = invoice.CustomerId;
                existing.SubDistributorId = invoice.SubdistributorId;

                var existingItems = db.SalesInvoiceItems
                    .Where(x => x.SalesInvoiceId == currentInvoiceId)
                    .ToList();

                if (existingItems.Any())
                {
                    db.SalesInvoiceItems.RemoveRange(existingItems);
                }

                db.SalesInvoiceItems.AddRange(items.Select(i => new STTproject.Models.SalesInvoiceItem
                {
                    SalesInvoiceId = currentInvoiceId,
                    SubdItemId = i.SubdItemId,
                    Quantity = i.Quantity,
                    Price = i.Price
                }));

                await db.SaveChangesAsync();
            }
        }

        isSaved = true;
    }

    void EnableEdit()
    {
        isSaved = false;
    }

    void OpenAddItemsModal()
    {
        modalItems.Clear();
        showAddItemsModal = true;
    }

    void CloseAddItemsModal()
    {
        showAddItemsModal = false;
        modalItems.Clear();
    }

    Task OnModalItemsSaved(List<InputItemModel> savedItems)
    {
        if (savedItems?.Any() == true)
        {
            items.AddRange(savedItems);
        }

        showAddItemsModal = false;
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OpenAddItemsModalFromShortcut()
    {
        if (isSaved)
        {
            showAddItemsModal = true;
            StateHasChanged();
        }

        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objRef = DotNetObjectReference.Create(this);
            jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "/js/salesinvoice.js");
            await jsModule.InvokeVoidAsync("registerF3", objRef);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (jsModule != null)
        {
            await jsModule.InvokeVoidAsync("unregisterF3");
            await jsModule.DisposeAsync();
            jsModule = null;
        }

        objRef?.Dispose();
    }

    bool showConfirmModal = false;
    bool isSaved = false;
    List<InputItemModel> modalItems = new();

    [Parameter]
    public int SubDistributorId { get; set; }

    SubDistributor? subd;

    SubdModel subdModel = new();
    InputInvoiceModel invoice = new();
    List<InputItemModel> items = new();
    List<SubdItem> subdItems = new();

    List<SubDistributor> subdList = new();

    protected override void OnParametersSet()
    {
        subdList = db.SubDistributors.ToList();
        subdItems = db.SubdItems
            .Where(i => i.SubDistributorId == SubDistributorId)
            .ToList();

        subd = subdList
            .FirstOrDefault(s => s.SubDistributorId == SubDistributorId);

        if (subd != null)
        {
            invoice.SubdistributorId = subd.SubDistributorId;
            UpdateSubdDisplay(subd);
        }
    }

    void CheckCustomer()
    {
        if (string.IsNullOrWhiteSpace(invoice.CustomerCode))
        {
            ClearCustomer();
            return;
        }

        var existing = db.Customers
            .FirstOrDefault(c => c.CustomerCode == invoice.CustomerCode);

        if (existing != null)
        {
            invoice.CustomerId = existing.CustomerId;
            invoice.CustomerType = existing.CustomerType;
            invoice.CustomerName = existing.CustomerName;
            invoice.CustomerAddress = existing.CustomerAddress;
        }
        else
        {
            ClearCustomer();
        }
    }

    void ClearCustomer()
    {
        invoice.CustomerId = 0;
        invoice.CustomerType = string.Empty;
        invoice.CustomerName = string.Empty;
        invoice.CustomerAddress = string.Empty;
    }

    public class SubdModel
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
    }

    void OnSubdChange()
    {
        var selected = subdList
            .FirstOrDefault(s => s.SubDistributorId == invoice.SubdistributorId);

        if (selected != null)
        {
            UpdateSubdDisplay(selected);
        }
    }
   
    void UpdateSubdDisplay(SubDistributor s)
    {
        subdModel.Code = s.SubdCode;
        subdModel.Name = s.SubdName;
        invoice.SubdistributorId = s.SubDistributorId;
    }
}