@using STTproject.Models

<div class="card">
    <h4 class="center">INVOICE ITEMS</h4>

    <table>
        <thead>
            <tr>
                <th>SKU Code</th>
                <th>Item</th>
                <th>Unit of Measure</th>
                <th>Quantity</th>
                <th>Price</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Items)
            {
                <tr>
                    <td>@item.ItemCode</td>
                    <td>@item.ItemName</td>
                    <td>@ResolveUomName(item.UomName)</td>
                    <td>@item.Quantity</td>
                    <td>@item.Price</td>
                </tr>
            }
        </tbody>
    </table>

    @if (Items.Any())
    {
        <div style="text-align: right; margin-top: 10px; font-weight: bold;">
            Total Price: @CalculateTotalPrice()
        </div>
    }
</div>

@code {
    [Parameter] public List<InputItemModel> Items { get; set; } = new();
    [Parameter] public EventCallback<List<InputItemModel>> ItemsChanged { get; set; }
    [Parameter] public List<SubdItem> AvailableItems { get; set; } = new();
    [Parameter] public List<SubdItemUom> AvailableUoms { get; set; } = new();

    private string ResolveUomName(int uomId)
    {
        var uom = AvailableUoms.FirstOrDefault(u => u.SubdItemUomId == uomId);
        return uom?.UomName ?? string.Empty;
    }

    private int CalculateTotalPrice()
    {
        return Items.Sum(i => i.Price);
    }

    private async Task RemoveItem(InputItemModel item)
    {
        Items.Remove(item);
        await ItemsChanged.InvokeAsync(Items);
    }
}
