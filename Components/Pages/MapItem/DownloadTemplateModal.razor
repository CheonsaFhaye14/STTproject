@if (ShowModal)
{
    <div class="modal-overlay">
        <div class="modal-box">
            <div class="modal-header">
                <h4>Filter Template</h4>
                <div class="modal-body">
                    <div class="form-group">
                        <label>SubDistributor</label>
                        <select>
                            <option value="value">All</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Principal</label>
                        <select>
                            <option value="value">All</option>
                        </select>
                    </div>
                    <button class="btn-primary" @onclick="ModalTemplate">Download</button>
                </div>
            </div>
        </div>
    </div>

}

    @code {
        [Parameter]
        public bool ShowModal { get; set; }

        [Parameter]
        public EventCallback ModalTemplate { get; set; }
    }
