@page "/mapitem"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components
@using STTproject.Components.Helper
@using STTproject.Models
@using STTproject.Services
@inject NavigationManager Navigation
@inject IHomeService homeService
@inject IMapItemService mapItemService
@inject IUserContextService userContext
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<!-- SUB DISTRIBUTOR + SEARCH + LOCATION -->
<button class="btn-primary" @onclick="GoBackToHome">Go Back</button>

<div class="header-with-search">
    <h3 class="header-title"><b>SUB DISTRIBUTORS</b></h3>
    <select class="search-input" @ref="subdSelectRef" value="@selectedSubdId" @onchange="OnSubdChangedAsync">
        <option value="0">-- Select Sub Distributor --</option>
        @foreach (var subd in subdList)
        {
            <option value="@subd.SubDistributorId">@subd.SubdName</option>
        }
    </select>
    <div class="location badge">
        LOCATION: <span>@locationText</span>
    </div>
</div>

<!-- DOWNLOAD TEMPLATE + IMPORT -->
<div class="button-group">
    <button class="btn-secondary">DOWNLOAD TEMPLATE</button>
    <button class="btn-secondary">IMPORT</button>
</div>

<!-- INPUT ROW -->
<div class="form-row">
    <div class="form-group">
        <h5>SKU CODE</h5>
        <InputText @bind-Value="itemCode" disabled="@(!IsSubDistributorSelected)" />
    </div>
    <div class="form-group">
        <h5>ITEM NAME</h5>
        <InputText @bind-Value="itemName" disabled="@(!IsSubDistributorSelected)" />
    </div>
    <div class="form-group">
        <h5>PRINCIPAL</h5>
        <select class="form-input" value="@selectedDropdownPrincipal" @onchange="OnPrincipalChanged"
                disabled="@(!IsSubDistributorSelected)">
            <option value="">-- Select Principal --</option>
            @foreach (var principalItem in PrincipalsDropdown)
            {
                <option value="@principalItem">@principalItem</option>
            }
        </select>
    </div>
    <div class="form-group">
        <h5>COMPANY ITEM</h5>
        <input class="form-input" list="companyItemsList" value="@GetSelectedCompanyItemName()" @onchange="OnCompanyItemDataListChanged"
               disabled="@(!IsSubDistributorSelected)" placeholder="-- Select Company Item --" />
        <datalist id="companyItemsList">
            @foreach (var item in FilteredCompanyItemsForDropdown)
            {
                <option value="@item.ItemName"></option>
            }
        </datalist>
    </div>
 <div class="form-actions">
        <button class="btn-primary" @onclick="AddItem" disabled="@(!IsSubDistributorSelected)">ADD</button>
    </div>
</div>





<!-- DASHBOARD PANELS -->
<div class="dashboard">
    <!-- PRINCIPALS -->
    <div class="card-section">
        <h3>PRINCIPALS</h3>
        <ul class="principal-list">
            <li class="@(string.IsNullOrWhiteSpace(selectedPrincipal) ? "principal-selected" : string.Empty)"
                @onclick="() => FilterByPrincipalAsync(null)">ALL</li>
            @foreach (var principal in principals)
            {
                <li class="@(principal == selectedPrincipal ? "principal-selected" : string.Empty)"
                    @onclick="() => FilterByPrincipalAsync(principal)">@principal</li>
            }
        </ul>
    </div>

    <!-- Company items -->
    <div class="card-section">
        <h3>COMPANY ITEMS</h3>
        <table class="mapping-table">
            <thead>
                <tr>
                    <th>COMPANY ITEM CODE</th>
                    <th>ITEM NAME</th>
                    <th>UNIT OF MEASURES</th>
                </tr>
            </thead>
            <tbody>
                @if (companyItems.Any())
                {
                    @foreach (var item in companyItems)
                    {
                        <tr>
                            <td>@item.CompanyItemCode</td>
                            <td>@item.ItemName</td>
                            <td>@item.UomName</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3">No company items found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- SUB DISTRIBUTOR ITEMS -->
    <div class="card-section">
        <h3>SUB DISTRIBUTOR ITEMS</h3>
        <table class="mapping-table">
            <thead>
                <tr>
                    <th>SUB ITEM CODE</th>
                    <th>ITEM NAME</th>
                    <th>UNIT OF MEASURES</th>
                    <th>ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @if (subDistributorItems.Any())
                {
                    @foreach (var item in subDistributorItems)
                    {
                        <tr>
                            <td>@item.SubItemCode</td>
                            <td>@item.Description</td>
                            <td>@item.UomName</td>
                            <td>
                                <button class="btn-primary">EDIT</button>
                                <button class="btn-primary">DELETE</button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5">No sub distributor items found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "uid")]
    public int? UserIdFromQuery { get; set; }

    // Form fields
    private int? selectedCompanyItemId;
    private string? selectedPrincipal;
    private string? itemCode;
    private string? itemName;
    private List<string> availableUoms = new();
    private Dictionary<string, decimal?> uomPrices = new();

    private List<SubDistributor> subdList = new();
    private ElementReference subdSelectRef;
    private int selectedSubdId;
    private string locationText = "---";
    private List<string> principals = new();
    private string? selectedDropdownPrincipal;
    private List<MapCompanyItemViewRow> companyItems = new();
    private List<MapSubDistributorItemRow> subDistributorItems = new();
    private List<CompanyItemDropdownItem> companyItemsForDropdown = new();

    private sealed class MapCompanyItemViewRow
    {
        public string CompanyItemCode { get; set; } = string.Empty;
        public string ItemName { get; set; } = string.Empty;
        public string UomName { get; set; } = string.Empty;
    }

    private bool IsSubDistributorSelected => selectedSubdId != 0;

    private IEnumerable<CompanyItemDropdownItem> FilteredCompanyItemsForDropdown =>
        string.IsNullOrWhiteSpace(selectedDropdownPrincipal)
            ? companyItemsForDropdown
            : companyItemsForDropdown.Where(i => i.Principal == selectedDropdownPrincipal);

    private IEnumerable<string> PrincipalsDropdown =>
        companyItemsForDropdown
            .Select(i => i.Principal)
            .Where(p => !string.IsNullOrWhiteSpace(p))
            .Distinct()
            .OrderBy(p => p);

    private void OnPrincipalChanged(ChangeEventArgs e)
    {
        selectedDropdownPrincipal = e.Value?.ToString();

        // Optional: Reset selected company item if it doesn't belong to the newly selected principal
        if (selectedCompanyItemId.HasValue && !string.IsNullOrWhiteSpace(selectedDropdownPrincipal))
        {
            var currentSelectedItem = companyItemsForDropdown.FirstOrDefault(i => i.CompanyItemId == selectedCompanyItemId.Value);
            if (currentSelectedItem != null && currentSelectedItem.Principal != selectedDropdownPrincipal)
            {
                selectedCompanyItemId = null;
                availableUoms.Clear();
                uomPrices.Clear();
            }
        }
    }

    private void GoBackToHome()
    {
        Navigation.NavigateTo("/");
    }
    protected override async Task OnParametersSetAsync()
    {
        if (!userContext.UserId.HasValue && UserIdFromQuery.HasValue)
        {
            userContext.UserId = UserIdFromQuery.Value;
        }

        if (!userContext.UserId.HasValue)
        {
            subdList = new();
            selectedSubdId = 0;
            locationText = "---";
            principals = new();
            selectedDropdownPrincipal = null;
            selectedPrincipal = null;
            companyItems = new();
            subDistributorItems = new();
            return;
        }

        subdList = await homeService.GetSubDistributorsAsync(userContext.UserId.Value);

        if (!subdList.Any())
        {
            selectedSubdId = 0;
            locationText = "---";
            principals = new();
            selectedDropdownPrincipal = null;
            selectedPrincipal = null;
            companyItems = new();
            subDistributorItems = new();
            return;
        }

        if (selectedSubdId != 0 && !subdList.Any(s => s.SubDistributorId == selectedSubdId))
        {
            selectedSubdId = 0;
        }

        UpdateSelectedSubdLocation();
        await LoadMapTablesAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await subdSelectRef.FocusAsync();
        }
    }

    private async Task OnSubdChangedAsync(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var subdId))
        {
            selectedSubdId = subdId;
        }
        else
        {
            selectedSubdId = 0;
        }

        UpdateSelectedSubdLocation();
        selectedDropdownPrincipal = null;
        selectedPrincipal = null;
        await LoadMapTablesAsync();
    }

    private void UpdateSelectedSubdLocation()
    {
        var selected = subdList.FirstOrDefault(s => s.SubDistributorId == selectedSubdId);
        locationText = selected == null
            ? "---"
            : FormatHelper.FormatLocation(selected.CityMunicipality, selected.Province ?? string.Empty);
    }

    private async Task LoadMapTablesAsync()
    {
        if (!userContext.UserId.HasValue)
        {
            principals = new();
            companyItems = new();
            subDistributorItems = new();
            companyItemsForDropdown = new();
            return;
        }

        // Load company items for dropdown (excluding already connected items)
        companyItemsForDropdown = await mapItemService.GetCompanyItemsForDropdownAsync(
            userContext.UserId.Value, selectedSubdId);

        principals = await mapItemService.GetMapItemPrincipalsAsync(userContext.UserId.Value, selectedSubdId);
        var companyRows = await mapItemService.GetMapCompanyItemsAsync(
            userContext.UserId.Value,
            selectedSubdId,
            selectedPrincipal);

        subDistributorItems = await mapItemService.GetMapSubDistributorItemsAsync(
            userContext.UserId.Value,
            selectedSubdId,
            selectedPrincipal);

        companyItems = companyRows
            .GroupBy(x => new { x.CompanyItemCode, x.Description })
            .Select(group => new MapCompanyItemViewRow
            {
                CompanyItemCode = group.Key.CompanyItemCode,
                ItemName = group.Key.Description,
                // Format: "Box of 12 - 120.00, Piece - 10.00"
                UomName = string.Join(", ", group
                    .Where(x => !string.IsNullOrWhiteSpace(x.UomName))
                    .Select(x => $"{x.UomName} - {x.Price:N2}"))
            })
            .OrderBy(x => x.CompanyItemCode)
            .ToList();
    }

    private async Task FilterByPrincipalAsync(string? principal)
    {
        selectedPrincipal = principal;
        await LoadMapTablesAsync();
    }

    private async Task OnCompanyItemChangedAsync(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var companyItemId) && companyItemId > 0)
        {
            await SelectCompanyItem(companyItemId);
        }
        else
        {
            ClearCompanyItemSelection();
        }
    }

    private async Task OnCompanyItemDataListChanged(ChangeEventArgs e)
    {
        var selectedItemName = e.Value?.ToString();
        var selectedItem = FilteredCompanyItemsForDropdown.FirstOrDefault(i => i.ItemName == selectedItemName);

        if (selectedItem != null)
        {
            await SelectCompanyItem(selectedItem.CompanyItemId);
        }
        else
        {
            ClearCompanyItemSelection();
        }
    }

    private async Task SelectCompanyItem(int companyItemId)
    {
        selectedCompanyItemId = companyItemId;
        var selectedItem = companyItemsForDropdown.FirstOrDefault(x => x.CompanyItemId == companyItemId);
        if (selectedItem != null)
        {
            selectedDropdownPrincipal = selectedItem.Principal;
            availableUoms = await mapItemService.GetCompanyItemUomsAsync(companyItemId);
            uomPrices = availableUoms.ToDictionary(u => u, u => (decimal?)null);
        }
    }

    private void ClearCompanyItemSelection()
    {
        selectedCompanyItemId = null;
        selectedDropdownPrincipal = null;
        availableUoms = new();
        uomPrices = new();
    }

    private string GetSelectedCompanyItemName()
    {
        if (!selectedCompanyItemId.HasValue) return string.Empty;
        var item = companyItemsForDropdown.FirstOrDefault(i => i.CompanyItemId == selectedCompanyItemId.Value);
        return item?.ItemName ?? string.Empty;
    }

    private async Task AddItem()
    {
        if (string.IsNullOrWhiteSpace(itemCode) || string.IsNullOrWhiteSpace(itemName) || !selectedCompanyItemId.HasValue || !userContext.UserId.HasValue)
        {
            return;
        }

        var prices = string.Join(", ", uomPrices.Where(p => p.Value.HasValue).Select(p => $"{p.Key}: {p.Value:N2}"));
        Console.WriteLine($"Added: CompanyItemId={selectedCompanyItemId}, Principal={selectedDropdownPrincipal}, SKU={itemCode}, ItemName={itemName}, Prices={prices}");

        var newItem = new SubdItem
        {
            SubdItemCode = itemCode,
            ItemName = itemName,
            SubDistributorId = selectedSubdId,
            CompanyItemId = selectedCompanyItemId.Value,
            IsActive = true,
            CreatedDate = DateTime.UtcNow,
            CreatedBy = userContext.UserId.Value
        };

        var success = await mapItemService.AddSubdItemAsync(newItem);
        if (success)
        {
            // Clear inputs
            itemCode = string.Empty;
            itemName = string.Empty;
            selectedCompanyItemId = null;
            selectedDropdownPrincipal = null;
            availableUoms.Clear();
            uomPrices.Clear();

            // Refresh tables
            await LoadMapTablesAsync();
        }
    }

    private void GoToCompanyItems()
    {
        Navigation.NavigateTo("/companyitems");
    }

}