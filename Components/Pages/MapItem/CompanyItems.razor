@page "/companyitems"

<div class="card-section company-items">
    <h3 class="title-center">COMPANY ITEMS</h3>

    <!-- Search bar -->
    <div class="search-bar center-bar">
        <input type="text" placeholder="Search Company Item..." class="search-input" @bind="searchTerm" />
        <button class="btn-search" @onclick="SearchCompanyItems">SEARCH</button>
    </div>

    <!-- Description + Price list -->
    <div class="company-list">
        <!-- Header row -->
        <div class="company-header">
            <span class="left-col">COMPANY ITEM DESCRIPTION</span>
            <span class="right-col">PRICE</span>
        </div>

        <!-- Item rows -->
        @foreach (var desc in companyItemDescriptions)
        {
            <div class="company-row @(selectedItem == desc ? "selected-row" : "")"
                 @onclick="() => SelectCompanyItem(desc)">
                <span class="left-col clickable">@desc.Description</span>
                <span class="right-col">@desc.Price</span>
            </div>
        }
    </div>
</div>

@code {
    private string searchTerm { get; set; } = string.Empty;

    private List<CompanyItemDescription> companyItemDescriptions = new()
    {
        new CompanyItemDescription { Description="Ovaltine Premium 400g Jar x 12's", Price=120 },
        new CompanyItemDescription { Description="Pringles SCO 102g Buy 2 Save 20", Price=99 }
    };

    public class CompanyItemDescription
    {
        public string Description { get; set; } = "";
        public decimal Price { get; set; }
    }

    private List<CurrentMapping> currentMappings = new();
    private CompanyItemDescription? selectedItem;

    public class CurrentMapping
    {
        public string CompanyItemCode { get; set; } = "";
        public string SubItemCode { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Price { get; set; }
    }

    private void SelectCompanyItem(CompanyItemDescription desc)
    {
        selectedItem = desc;
        currentMappings.Add(new CurrentMapping
        {
            CompanyItemCode = "AUTO-GEN",
            SubItemCode = "01GMA06",
            Description = desc.Description,
            Price = desc.Price
        });
        Console.WriteLine($"Selected {desc.Description} and added to CURRENT MAPPING");
    }

    private void SearchCompanyItems()
    {
        Console.WriteLine($"Searching for {searchTerm}");
    }
}
