@using STTproject.Models
@using STTproject.Services
@using STTproject.Models.Tables
@if (ShowModal)
{
    <div class="modal-overlay">
        <div class="modal-box">
            <div class="modal-header">
                <h4>Download Template</h4>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Sub Distributor</label>
                    <select @bind="selectedSubdistributorId">
                        <option value="0">-- All Sub Distributors --</option>
                        @foreach (var subd in SubdList)
                        {
                            <option value="@subd.SubDistributorId">@subd.SubdName</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Principal (Optional)</label>
                    <select @bind="selectedPrincipal">
                        <option value="">-- All Principals --</option>
                        @foreach (var principal in PrincipalList)
                        {
                            <option value="@principal">@principal</option>
                        }
                    </select>
                </div>
                <div class="modal-actions">
                    <button class="btn-primary" @onclick="DownloadClicked">Download</button>
                    <button class="btn-secondary" @onclick="CancelClicked">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool ShowModal { get; set; }
    [Parameter]
    public List<SubDistributor> SubdList { get; set; } = new();
    [Parameter]
    public List<string> PrincipalList { get; set; } = new();
    [Parameter]
    public EventCallback<(int SubdistributorId, string? Principal)> OnDownload { get; set; }
    [Parameter]
    public EventCallback OnCancel { get; set; }

    private int selectedSubdistributorId = 0;
    private string? selectedPrincipal = string.Empty;

    private async Task DownloadClicked()
    {
        await OnDownload.InvokeAsync((selectedSubdistributorId, selectedPrincipal));
    }

    private async Task CancelClicked()
    {
        selectedSubdistributorId = 0;
        selectedPrincipal = string.Empty;
        await OnCancel.InvokeAsync();
    }
}
