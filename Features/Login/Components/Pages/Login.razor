@layout STTproject.Shared.Layout.EmptyLayout
@page "/"

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<div class="login-container">
    <div class="login-card">
        <h2 class="login-title">LOGIN</h2>

        <form method="post" action="/login">

            <div class="login-field">
                <label>Username</label>
                <input name="username" placeholder="Enter username" value="@Username" />
            </div>

            <div class="login-field">
                <label>Password
                </label>
                <div class="password-wrapper">
                    <input id="passwordInput" name="password" type="password" placeholder="Enter password"
                           class="password-input" />
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(loginErrorMessage))
            {
                <p class="login-error">@loginErrorMessage</p>
            }

            <div class="login-field">
                <div class="login-role-options">
                    <label>
                        <input type="radio" name="role" value="Admin" checked="@IsAdminSelected" />
                        Admin
                    </label>
                    <label>
                        <input type="radio" name="role" value="Encoder" checked="@IsEncoderSelected" />
                        Encoder
                    </label>
                </div>
            </div>

            <div class="login-field remember-me-field">
                <label>
                    <input type="checkbox" name="rememberMe" value="true" checked="@RememberMe" />
                    Remember Me
                </label>
            </div>

            <button class="login-btn" type="submit">LOGIN</button>
            <label>Forget Password?</label>
        </form>
    </div>
</div>


