@using STTproject.Features.Admin.Users.DTOs
@inject STTproject.Features.Admin.Users.Services.IAdminUserService AdminUserService
<link rel="stylesheet" href="css/Table.css" asp-append-version="true" />

<div class="clt-page">

    <div class="clt-layout">

        <!-- Sidebar -->
        <aside class="clt-sidebar">

            <div class="clt-sidebar-stats">
                <div class="clt-stat">
                    <span class="clt-stat-label">Total</span>
                    <span class="clt-stat-value">@totalCount</span>
                </div>
                <div class="clt-stat">
                    <span class="clt-stat-label">Active</span>
                    <span class="clt-stat-value clt-stat-active">@activeCount</span>
                </div>
                <div class="clt-stat">
                    <span class="clt-stat-label">Inactive</span>
                    <span class="clt-stat-value clt-stat-inactive">@inactiveCount</span>
                </div>
            </div>

            <div class="clt-divider"></div>

            <!-- Search -->
            <div class="clt-filter-group">
                <label class="clt-filter-label">Search</label>
                <div class="clt-search-wrap">
                    <svg class="clt-search-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                         stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                    </svg>
                    <input class="clt-search-input" type="text" @bind:event="oninput" @bind="SearchTerm"
                           placeholder="Search…" />
                </div>
            </div>

            <!-- Status filter -->
            <div class="clt-filter-group">
                <label class="clt-filter-label">Status</label>
                <div class="clt-radio-group">
                    <label class="clt-radio-option @(SelectedStatus == "" ? "selected" : "")">
                        <input type="radio" name="status" value=""
                               @onchange="() => OnFilterChanged(status: string.Empty)" checked="@(SelectedStatus == "")" />
                        <span>All</span>
                    </label>
                    <label class="clt-radio-option @(SelectedStatus == "active" ? "selected" : "")">
                        <input type="radio" name="status" value="active"
                               @onchange='() => OnFilterChanged(status: "active")'
                               checked="@(SelectedStatus == "active")" />
                        <span>Active</span>
                    </label>
                    <label class="clt-radio-option @(SelectedStatus == "inactive" ? "selected" : "")">
                        <input type="radio" name="status" value="inactive"
                               @onchange='() => OnFilterChanged(status: "inactive")'
                               checked="@(SelectedStatus == "inactive")" />
                        <span>Inactive</span>
                    </label>
                </div>
            </div>

            <!-- User Role filter -->
            <div class="clt-filter-group">
                <label class="clt-filter-label" for="typeFilter">User Role</label>
                <select id="typeFilter" class="clt-select"
                        @onchange="e => OnFilterChanged(role: e.Value?.ToString() ?? string.Empty)">
                    <option value="">All roles</option>
                    <option value="Admin" selected="@("Admin" == SelectedRole)">Admin</option>
                    <option value="Encoder" selected="@("Encoder" == SelectedRole)">Encoder</option>
                </select>
            </div>

            @if (HasActiveFilters)
            {
                <button class="clt-clear-btn" @onclick="ClearFilters">Clear all filters</button>
            }

        </aside>

        <!-- Main content -->
        <main class="clt-main">
            <div class="clt-table-card">
                <div class="clt-table-scroll">
                    <table class="clt-table">
                        <thead>
                            <tr>
                                <th @onclick='() => SortBy("UserName")' style="cursor:pointer">
                                    Username @SortIndicator("UserName")
                                </th>
                                <th @onclick='() => SortBy("FullName")' style="cursor:pointer">
                                    Full Name @SortIndicator("FullName")
                                </th>
                                <th @onclick='() => SortBy("Role")' style="cursor:pointer">
                                    Role @SortIndicator("Role")
                                </th>
                                <th @onclick='() => SortBy("Email")' style="cursor:pointer">
                                    Email @SortIndicator("Email")
                                </th>
                                <th @onclick='() => SortBy("CreatedDate")' style="cursor:pointer">
                                    Created @SortIndicator("CreatedDate")
                                </th>
                                <th @onclick='() => SortBy("IsActive")' style="cursor:pointer">
                                    Status @SortIndicator("IsActive")
                                </th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (isLoading)
                            {
                                <tr>
                                    <td colspan="7" class="clt-empty">
                                        <div class="clt-empty-inner">
                                            <p>Loading…</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                            else if (!PagedUsers.Any())
                            {
                                <tr>
                                    <td colspan="7" class="clt-empty">
                                        <div class="clt-empty-inner">
                                            <p>No users match your filters</p>
                                            <button class="clt-clear-btn" @onclick="ClearFilters">Clear filters</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var user in PagedUsers)
                                {
                                    <tr class="@(!user.IsActive ? "clt-row-inactive" : "")">
                                        <td><span class="clt-code">@user.UserId</span></td>
                                        <td class="clt-name">@user.UserName</td>
                                        <td><span class="clt-type-badge">@user.Role</span></td> 
                                        <td class="clt-muted">@user.Email</td>
                                        <td class="clt-muted">
                                            @user.CreatedDate.ToString("MMM d, yyyy hh:mm tt")
                                        </td>
                                        <td>
                                            @if (user.IsActive)
                                            {
                                                <span class="clt-status clt-status-active">Active</span>
                                            }
                                            else
                                            {
                                                <span class="clt-status clt-status-inactive">Inactive</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="clt-actions">
                                                <button class="clt-btn-edit"
                                                        @onclick="() => OnEditUser.InvokeAsync(user.UserId)">Edit</button>
                                                @if (user.IsActive)
                                                {
                                                    <button class="clt-btn-toggle clt-btn-deactivate"
                                                            @onclick="() => SetActive(user.UserId, false)">Deactivate</button>
                                                }
                                                else
                                                {
                                                    <button class="clt-btn-toggle clt-btn-activate"
                                                            @onclick="() => SetActive(user.UserId, true)">Activate</button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="clt-footer">
                <span class="clt-footer-count">
                    Showing @PagedUsers.Count of @totalCount users
                </span>
                @if (totalPages > 1)
                {
                    <div class="clt-pagination">
                        <button class="clt-page-btn" disabled="@(currentPage == 1)"
                                @onclick="() => GoToPage(currentPage - 1)">←</button>
                        <span>Page @currentPage of @totalPages</span>
                        <button class="clt-page-btn" disabled="@(currentPage >= totalPages)"
                                @onclick="() => GoToPage(currentPage + 1)">→</button>
                    </div>
                }
            </div>
        </main>

    </div>
    <ConfirmModal Show="showToggleConfirmModal" Title="Confirm Status Change" Message="@toggleConfirmMessage"
                  OnYes="ConfirmToggle" OnNo="CancelToggle" />
</div>

@code {
    [Parameter] public EventCallback OnLoaded { get; set; }
    [Parameter] public EventCallback<int> OnCountChanged { get; set; }
    private List<UserListDto> PagedUsers { get; set; } = new();
    private List<(int Id, string? Name)> SubDistributors { get; set; } = new();
    // Add this helper to @code
    private static readonly TimeZoneInfo PhTimeZone =
        TimeZoneInfo.FindSystemTimeZoneById(
            OperatingSystem.IsWindows() ? "Singapore Standard Time" : "Asia/Manila");

    private string _searchTerm = "";
    private string SearchTerm
    {
        get => _searchTerm;
        set
        {
            _searchTerm = value;
            _debounceTimer?.Dispose();
            _debounceTimer = new System.Threading.Timer(async _ =>
            {
                currentPage = 1;
                await InvokeAsync(LoadPageAsync); // ← add InvokeAsync here
            }, null, 400, Timeout.Infinite);
        }
    }

    private ConfirmModal? toggleConfirmModal;
    private bool showToggleConfirmModal;
    private int pendingToggleId;
    private bool pendingToggleStatus;
    private string toggleConfirmMessage = "";

    [Parameter] public EventCallback<int> OnEditUser { get; set; }

    private string SelectedRole { get; set; } = "";
    private string SelectedStatus { get; set; } = "";
    private int? SelectedSubDistributorId { get; set; }

    private int currentPage = 1;
    private const int pageSize = 50;
    private int totalCount = 0;
    private int activeCount = 0;
    private int inactiveCount = 0;
    private int totalPages => (int)Math.Ceiling(totalCount / (double)pageSize);

    private bool isLoading = true;
    private System.Threading.Timer? _debounceTimer;

    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(_searchTerm) ||
        SelectedSubDistributorId.HasValue ||
        !string.IsNullOrWhiteSpace(SelectedRole) ||
        !string.IsNullOrWhiteSpace(SelectedStatus);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadPageAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading users: {ex.Message}");
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    public async Task LoadPageAsync()
    {
        isLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var (items, total) = await AdminUserService.GetPagedAsync(
                currentPage, pageSize, _searchTerm, SelectedStatus,
                SelectedRole, SelectedSubDistributorId,
                SortColumn, SortAscending); // ← add these

            PagedUsers = items.ToList();
            totalCount = total;

            // Get active/inactive counts (only on first load or filter change)
            var (_, activeTotal) = await AdminUserService.GetPagedAsync(
                1, 1, _searchTerm, "active", SelectedRole, SelectedSubDistributorId);
            var (_, inactiveTotal) = await AdminUserService.GetPagedAsync(
                1, 1, _searchTerm, "inactive", SelectedRole, SelectedSubDistributorId);
            activeCount = activeTotal;
            inactiveCount = inactiveTotal;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading page: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
            if (OnCountChanged.HasDelegate)
                await OnCountChanged.InvokeAsync(totalCount);
            if (OnLoaded.HasDelegate)
                await OnLoaded.InvokeAsync();
        }
    }

    private async Task OnFilterChanged(string? status = null, string? role = null, string? subdId = null)
    {
        if (status != null) SelectedStatus = status;
        if (role != null) SelectedRole = role;
        if (subdId != null)
            SelectedSubDistributorId = int.TryParse(subdId, out var id) && id > 0 ? id : null;

        currentPage = 1;
        await LoadPageAsync();
    }

    private async Task GoToPage(int page)
    {
        currentPage = page;
        await LoadPageAsync();
    }

    private async Task ClearFilters()
    {
        _searchTerm = "";
        SelectedSubDistributorId = null;
        SelectedRole = "";
        SelectedStatus = "";
        currentPage = 1;
        await LoadPageAsync();
    }

    private void SetActive(int id, bool isActive)
    {
        pendingToggleId = id;
        pendingToggleStatus = isActive;
        toggleConfirmMessage = isActive
            ? "Are you sure you want to activate this user?"
            : "Are you sure you want to deactivate this user?";
        showToggleConfirmModal = true;
    }

    private async Task ConfirmToggle()
    {
        showToggleConfirmModal = false;
        await AdminUserService.ToggleUserStatusAsync(pendingToggleId, pendingToggleStatus);
        var user = PagedUsers.FirstOrDefault(x => x.UserId == pendingToggleId);
        if (user != null) user.IsActive = pendingToggleStatus;
        await InvokeAsync(StateHasChanged);
    }

    private void CancelToggle() => showToggleConfirmModal = false;
    private string SortColumn { get; set; } = "UserName";
    private bool SortAscending { get; set; } = true;

    private async Task SortBy(string column)
    {
        if (SortColumn == column)
            SortAscending = !SortAscending;
        else
        {
            SortColumn = column;
            SortAscending = true;
        }
        currentPage = 1;
        await LoadPageAsync();
    }

    private string SortIndicator(string column)
    {
        if (SortColumn != column)
        {
            return string.Empty;
        }

        return SortAscending ? " ▲" : " ▼";
    }
}