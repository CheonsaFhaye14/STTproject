@page "/admin/users"
@layout STTproject.Shared.Layout.Admin.AdminSideBar
@using STTproject.Features.Admin.Users.Components.Modals
@using STTproject.Features.Admin.Users.Components.Sections
@if (isLoading)
{
    <div class="loading-overlay">
        <div class="loading-bar-track">
            <div class="loading-bar-fill"></div>
        </div>
        <p>Loading users…</p>
    </div>
}


<div style="@(isLoading ? "display:none;" : "")">
    <div class="clt-page">
        @* ------------- Header ----------------- *@
        <div class="clt-page-header">
            <div>
                <h1 class="clt-page-title">Users</h1>
                <p class="clt-page-sub">@totalCount total users</p>
            </div>
            <button class="clt-add-btn" @onclick="OpenAddUserModal">
                <span class="clt-add-icon">+</span> Add user
            </button>
        </div>

        @* ------------- User List Table ----------------- *@
        <UserListTable @ref="userTable" OnLoaded="OnTableLoaded" OnCountChanged="OnCountChanged"
                       OnEditUser="OpenEditModal" />

<ConfirmModal @ref="confirmAddModal" Show="showConfirmAddModal"
              Title="@(editUserId.HasValue ? "Confirm Update of User" : "Confirm Creation of User")"
              Message="@(showConfirmError ? null : (editUserId.HasValue ? "Are you sure you want to save changes to this user?" : "Are you sure you want to create this user?"))"
              ErrorMessage="@confirmErrorMessage"
              ShowError="showConfirmError"
              OnYes="ConfirmAddUser" OnNo="CancelConfirm"
              OnErrorConfirm="DismissConfirmError" />


        @if (showAddModal)
        {
            <AddUser @ref="addUserModal" UserId="editUserId" onCancel="CancelAddUser" OnRequestConfirm="OpenConfirmModal" />
        }

    </div>
</div>


@code {
    private ConfirmModal? confirmAddModal;
    private bool showConfirmAddModal;
    private bool showConfirmError;
    private string? confirmErrorMessage;
    private bool showAddModal;
    private bool isLoading = true;
    private int totalCount = 0;
    private UserListTable? userTable;
    private AddUser? addUserModal;

    private async Task OnTableLoaded()
    {
        isLoading = false;
        await InvokeAsync(StateHasChanged);
    }
    private int? editUserId;

    private void OpenAddUserModal()
    {
        editUserId = null; // new user
        showAddModal = true;
    }

    // called from UserListTable OnViewUser
    private void OpenEditModal(int id)
    {
        editUserId = id;
        showAddModal = true;
    }

    private void OnCountChanged(int count) => totalCount = count;

    private void OpenConfirmModal()
    {
        showConfirmError = false;
        confirmErrorMessage = null;
        showConfirmAddModal = true;
    }

    private void CancelConfirm() => showConfirmAddModal = false;

    private void CancelAddUser() => showAddModal = false;

    private async Task ConfirmAddUser()
    {
        if (addUserModal == null) return;

        var (success, error) = await addUserModal.SubmitAsync();

        if (success)
        {
            showConfirmAddModal = false;
            showAddModal = false;
            if (userTable != null)
                await userTable.LoadPageAsync();
        }
        else
        {
            // Keep ConfirmModal open but switch it into error mode.
            confirmErrorMessage = error ?? "An unexpected error occurred. Please try again.";
            showConfirmError = true;
        }
    }

    private void DismissConfirmError()
    {
        // Close the confirm modal entirely; the AddUser modal stays open
        // so the user can fix the field (e.g. duplicate username) and retry.
        showConfirmError = false;
        confirmErrorMessage = null;
        showConfirmAddModal = false;
    }
}