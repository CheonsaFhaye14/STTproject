@using STTproject.Features.Admin.Customers.DTOs
@inject STTproject.Features.Admin.Customers.Services.IAdminCustomerService AdminCustomerService

<div class="card">
    <div class="filters">
        @* search filter for table include customer code, name, type and address *@
        <div class="filter-group">
            <label>Search:</label>
            <input type="text" @bind="SearchTerm" placeholder="Search customers..." />
        </div>
        <div class="filter-group">
            <label>Subdistributor:</label>
            <select id="subdistributorFilter" @bind="SelectedSubDistributorId">
                <option value="">All Subdistributors</option>
                @foreach (var subdistributor in SubDistributors)
                {
                    <option value="@subdistributor.Id">@subdistributor.Name</option>
                }
            </select>
        </div>
        <div class="filter-group">
            <label>Customer Type:</label>
            <select id="customerTypeFilter" @bind="SelectedCustomerType">
                <option value="">All Types</option>
                @foreach (var type in CustomerTypes)
                {
                    <option value="@type">@type</option>
                }
            </select>
        </div>
        <div class="filter-group">
            <label>Status:</label>
            <select id="statusFilter" @bind="SelectedStatus">
                <option value="">All</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
            </select>
        </div>
    </div>

    <table class="customer-table">
        <thead>
            <tr>
                <th>Customer Code</th>
                <th>Customer Name</th>
                <th>Customer Type</th>
                <th>Subdistributor</th>
                <th>Created Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var customer in FilteredCustomers)
            {
                <tr>
                    <td>@customer.CustomerCode</td>
                    <td>@customer.CustomerName</td>
                    <td>@customer.CustomerType</td>
                    <td>@customer.SubDistributorName</td>
                    <td>@customer.CreatedDate.ToString("yyyy-MM-dd")</td>
                    <td>
                        <button class="btn btn-primary" @onclick="() => EditCustomer(customer.CustomerId)">Edit</button>
                        @if (customer.IsActive)
                        {
                            <button class="btn btn-secondary" @onclick="() => SetActive(customer.CustomerId, false)">Set
                                Inactive</button>
                            }
                    else
                            {
                                <button class="btn btn-success" @onclick="() => SetActive(customer.CustomerId, true)">Set
                                    Active</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>

@code {
    private List<CustomerListDto> Customers { get; set; } = new();
    private string? SearchTerm { get; set; }
    private int? SelectedSubDistributorId { get; set; }
    private string? SelectedCustomerType { get; set; }
    private string? SelectedStatus { get; set; }
    private List<(int Id, string Name)> SubDistributors { get; set; } = new();
    private List<string> CustomerTypes { get; set; } = new() { "Retail", "Wholesale", "Distributor", "Other" };

    private IEnumerable<CustomerListDto> FilteredCustomers => Customers.Where(c =>
        (string.IsNullOrWhiteSpace(SearchTerm) || (c.CustomerName?.Contains(SearchTerm,
System.StringComparison.OrdinalIgnoreCase) == true) || (c.CustomerCode?.Contains(SearchTerm,
System.StringComparison.OrdinalIgnoreCase) == true))
        && (!SelectedSubDistributorId.HasValue || c.SubDistributorId == SelectedSubDistributorId.Value)
        && (string.IsNullOrWhiteSpace(SelectedCustomerType) || c.CustomerType == SelectedCustomerType)
        && (string.IsNullOrWhiteSpace(SelectedStatus) || (SelectedStatus == "active" ? c.IsActive : !c.IsActive))
    );

    protected override async Task OnInitializedAsync()
    {
        var list = await AdminCustomerService.GetAllAsync();
        Customers = list.ToList();
    }

    private void EditCustomer(int id)
    {
        // TODO: open modal and populate for edit
    }

    private async Task SetActive(int id, bool isActive)
    {
        await AdminCustomerService.ToggleCustomerStatusAsync(id, isActive);
        var c = Customers.FirstOrDefault(x => x.CustomerId == id);
        if (c != null) c.IsActive = isActive;
        StateHasChanged();
    }
}

