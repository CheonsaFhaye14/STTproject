@using STTproject.Features.Admin.Customers.DTOs
@inject STTproject.Features.Admin.Customers.Services.IAdminCustomerService AdminCustomerService

<div class="clt-page">

    <div class="clt-layout">

        <!-- Sidebar -->
        <aside class="clt-sidebar">

            <div class="clt-sidebar-stats">
                <div class="clt-stat">
                    <span class="clt-stat-label">Total</span>
                    <span class="clt-stat-value">@totalCount</span>
                </div>
                <div class="clt-stat">
                    <span class="clt-stat-label">Active</span>
                    <span class="clt-stat-value clt-stat-active">@activeCount</span>
                </div>
                <div class="clt-stat">
                    <span class="clt-stat-label">Inactive</span>
                    <span class="clt-stat-value clt-stat-inactive">@inactiveCount</span>
                </div>
            </div>

            <div class="clt-divider"></div>

            <!-- Search -->
            <div class="clt-filter-group">
                <label class="clt-filter-label">Search</label>
                <div class="clt-search-wrap">
                    <svg class="clt-search-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                         stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                    </svg>
                    <input class="clt-search-input" type="text" @bind:event="oninput" @bind="SearchTerm"
                           placeholder="Name or code…" />
                </div>
            </div>

            <!-- Status filter -->
            <div class="clt-filter-group">
                <label class="clt-filter-label">Status</label>
                <div class="clt-radio-group">
                    <label class="clt-radio-option @(SelectedStatus == "" ? "selected" : "")">
                        <input type="radio" name="status" value=""
                               @onchange="() => OnFilterChanged(status: string.Empty)" checked="@(SelectedStatus == "")" />
                        <span>All</span>
                    </label>
                    <label class="clt-radio-option @(SelectedStatus == "active" ? "selected" : "")">
                        <input type="radio" name="status" value="active"
                               @onchange='() => OnFilterChanged(status: "active")'
                               checked="@(SelectedStatus == "active")" />
                        <span>Active</span>
                    </label>
                    <label class="clt-radio-option @(SelectedStatus == "inactive" ? "selected" : "")">
                        <input type="radio" name="status" value="inactive"
                               @onchange='() => OnFilterChanged(status: "inactive")'
                               checked="@(SelectedStatus == "inactive")" />
                        <span>Inactive</span>
                    </label>
                </div>
            </div>

            <!-- Customer type filter -->
            <div class="clt-filter-group">
                <label class="clt-filter-label" for="typeFilter">Customer type</label>
                <select id="typeFilter" class="clt-select"
                        @onchange="e => OnFilterChanged(customerType: e.Value?.ToString() ?? string.Empty)">
                    <option value="">All types</option>
                    @foreach (var type in AllCustomerTypes)
                    {
                        <option value="@type" selected="@(SelectedCustomerType == type)">@type</option>
                    }
                </select>
            </div>

            <!-- Subdistributor filter -->
            <div class="clt-filter-group">
                <label class="clt-filter-label" for="subdistFilter">Subdistributor</label>
                <select id="subdistFilter" class="clt-select"
                        @onchange="e => OnFilterChanged(subdId: e.Value?.ToString() ?? string.Empty)">
                    <option value="">All subdistributors</option>
                    @foreach (var sd in SubDistributors)
                    {
                        <option value="@sd.Id" selected="@(SelectedSubDistributorId?.ToString() == sd.Id.ToString())">
                            @(sd.Name ?? "—")</option>
                        }
                    </select>
                </div>

                @if (HasActiveFilters)
                {
                    <button class="clt-clear-btn" @onclick="ClearFilters">Clear all filters</button>
                }

            </aside>

            <!-- Main content -->
            <main class="clt-main">
                <div class="clt-table-card">
                    <div class="clt-table-scroll">
                        <table class="clt-table">
                            <thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Customer name</th>
                                    <th>Type</th>
                                    <th>Subdistributor</th>
                                    <th>Created</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (isLoading)
                                {
                                    <tr>
                                        <td colspan="7" class="clt-empty">
                                            <div class="clt-empty-inner">
                                                <p>Loading…</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                else if (!PagedCustomers.Any())
                                {
                                    <tr>
                                        <td colspan="7" class="clt-empty">
                                            <div class="clt-empty-inner">
                                                <p>No customers match your filters</p>
                                                <button class="clt-clear-btn" @onclick="ClearFilters">Clear filters</button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var customer in PagedCustomers)
                                    {
                                        <tr class="@(!customer.IsActive ? "clt-row-inactive" : "")">
                                            <td><span class="clt-code">@customer.CustomerCode</span></td>
                                            <td class="clt-name">@customer.CustomerName</td>
                                            <td><span class="clt-type-badge">@customer.CustomerType</span></td>
                                            <td class="clt-muted">@customer.SubDistributorName</td>
                                            <td class="clt-muted">@customer.CreatedDate.ToString("MMM d, yyyy")</td>
                                            <td>
                                                @if (customer.IsActive)
                                                {
                                                    <span class="clt-status clt-status-active">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="clt-status clt-status-inactive">Inactive</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="clt-actions">
                                                    <button class="clt-btn-edit"
                                                            @onclick="() => OnViewCustomer.InvokeAsync(customer.CustomerId)">View</button>
                                                    @if (customer.IsActive)
                                                    {
                                                        <button class="clt-btn-toggle clt-btn-deactivate"
                                                                @onclick="() => SetActive(customer.CustomerId, false)">Deactivate</button>
                                                    }
                                                    else
                                                    {
                                                        <button class="clt-btn-toggle clt-btn-activate"
                                                                @onclick="() => SetActive(customer.CustomerId, true)">Activate</button>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="clt-footer">
                    <span class="clt-footer-count">
                        Showing @PagedCustomers.Count of @totalCount customers
                    </span>
                    @if (totalPages > 1)
                    {
                        <div class="clt-pagination">
                            <button class="clt-page-btn" disabled="@(currentPage == 1)"
                                    @onclick="() => GoToPage(currentPage - 1)">←</button>
                            <span>Page @currentPage of @totalPages</span>
                            <button class="clt-page-btn" disabled="@(currentPage >= totalPages)"
                                    @onclick="() => GoToPage(currentPage + 1)">→</button>
                        </div>
                    }
                </div>
            </main>

        </div>
        <ConfirmModal Show="showToggleConfirmModal" Title="Confirm Status Change" Message="@toggleConfirmMessage"
                      OnYes="ConfirmToggle" OnNo="CancelToggle" />
    </div>

@code {
    [Parameter] public EventCallback OnLoaded { get; set; }
    [Parameter] public EventCallback<int> OnCountChanged { get; set; }
    private List<CustomerListDto> PagedCustomers { get; set; } = new();
    private List<(int Id, string? Name)> SubDistributors { get; set; } = new();
    private List<string> AllCustomerTypes { get; set; } = new();

    private string _searchTerm = "";
    private string SearchTerm
    {
        get => _searchTerm;
        set
        {
            _searchTerm = value;
            _debounceTimer?.Dispose();
            _debounceTimer = new System.Threading.Timer(async _ =>
            {
                currentPage = 1;
                await InvokeAsync(LoadPageAsync); // ← add InvokeAsync here
            }, null, 400, Timeout.Infinite);
        }
    }

    private ConfirmModal? toggleConfirmModal;
    private bool showToggleConfirmModal;
    private int pendingToggleId;
    private bool pendingToggleStatus;
    private string toggleConfirmMessage = "";

    [Parameter] public EventCallback<int> OnViewCustomer { get; set; }

    private string SelectedCustomerType { get; set; } = "";
    private string SelectedStatus { get; set; } = "";
    private int? SelectedSubDistributorId { get; set; }

    private int currentPage = 1;
    private const int pageSize = 50;
    private int totalCount = 0;
    private int activeCount = 0;
    private int inactiveCount = 0;
    private int totalPages => (int)Math.Ceiling(totalCount / (double)pageSize);

    private bool isLoading = true;
    private System.Threading.Timer? _debounceTimer;

    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(_searchTerm) ||
        SelectedSubDistributorId.HasValue ||
        !string.IsNullOrWhiteSpace(SelectedCustomerType) ||
        !string.IsNullOrWhiteSpace(SelectedStatus);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            SubDistributors = (await AdminCustomerService.GetSubDistributorsAsync())
                .Select(sd => (sd.SubDistributorId, (string?)sd.SubDistributorName))
                .ToList();

            AllCustomerTypes = (await AdminCustomerService.GetCustomerTypesAsync()).ToList();

            await LoadPageAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading customers: {ex.Message}");
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    public async Task LoadPageAsync()
    {
        isLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var (items, total) = await AdminCustomerService.GetPagedAsync(
                currentPage, pageSize, _searchTerm, SelectedStatus,
                SelectedCustomerType, SelectedSubDistributorId);

            PagedCustomers = items.ToList();
            totalCount = total;

            // Get active/inactive counts (only on first load or filter change)
            var (_, activeTotal) = await AdminCustomerService.GetPagedAsync(
                1, 1, _searchTerm, "active", SelectedCustomerType, SelectedSubDistributorId);
            var (_, inactiveTotal) = await AdminCustomerService.GetPagedAsync(
                1, 1, _searchTerm, "inactive", SelectedCustomerType, SelectedSubDistributorId);
            activeCount = activeTotal;
            inactiveCount = inactiveTotal;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading page: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
            if (OnCountChanged.HasDelegate)
                await OnCountChanged.InvokeAsync(totalCount);
            if (OnLoaded.HasDelegate)
                await OnLoaded.InvokeAsync();
        }
    }

    private async Task OnFilterChanged(string? status = null, string? customerType = null, string? subdId = null)
    {
        if (status != null) SelectedStatus = status;
        if (customerType != null) SelectedCustomerType = customerType;
        if (subdId != null)
            SelectedSubDistributorId = int.TryParse(subdId, out var id) && id > 0 ? id : null;

        currentPage = 1;
        await LoadPageAsync();
    }

    private async Task GoToPage(int page)
    {
        currentPage = page;
        await LoadPageAsync();
    }

    private async Task ClearFilters()
    {
        _searchTerm = "";
        SelectedSubDistributorId = null;
        SelectedCustomerType = "";
        SelectedStatus = "";
        currentPage = 1;
        await LoadPageAsync();
    }

    private void SetActive(int id, bool isActive)
    {
        pendingToggleId = id;
        pendingToggleStatus = isActive;
        toggleConfirmMessage = isActive
            ? "Are you sure you want to activate this customer?"
            : "Are you sure you want to deactivate this customer?";
        showToggleConfirmModal = true;
    }

    private async Task ConfirmToggle()
    {
        showToggleConfirmModal = false;
        await AdminCustomerService.ToggleCustomerStatusAsync(pendingToggleId, pendingToggleStatus);
        var customer = PagedCustomers.FirstOrDefault(x => x.CustomerId == pendingToggleId);
        if (customer != null) customer.IsActive = pendingToggleStatus;
        await InvokeAsync(StateHasChanged);
    }

    private void CancelToggle() => showToggleConfirmModal = false;
}