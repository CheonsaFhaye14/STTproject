@page "/admin/customer"
@layout STTproject.Shared.Layout.Admin.AdminSideBar
@using STTproject.Features.Admin.Customers.Components.Modals
@using STTproject.Features.Admin.Customers.Components.Sections
@using STTproject.Shared.Components

@if (isLoading)
{
    <div class="loading-overlay">
        <div class="loading-bar-track">
            <div class="loading-bar-fill"></div>
        </div>
        <p>Loading customers…</p>
    </div>
}

<div style="@(isLoading ? "display:none;" : "")">

    <CustomerListTable OnLoaded="OnTableLoaded" />

    <ConfirmModal @ref="confirmAddModal" Show="showConfirmAddModal" Title="Confirm Creation of Customer"
                  Message="Are you sure you want to create this customer?" OnYes="ConfirmAddCustomer" />

    @if (showAddModal)
    {
        <AddCustomer OnCustomerCreated="OnCustomerCreated" onCancel="CancelAddCustomer"/>
    }
</div>

@code {
    private ConfirmModal? confirmAddModal;
    private bool showConfirmAddModal;
    private bool showAddModal;
    private bool isLoading = true;

    private async Task OnTableLoaded()
    {
        isLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private void OpenAddCustomerModal() => showAddModal = true;
    private Task ConfirmAddCustomer() => Task.CompletedTask;

    private Task OnCustomerCreated()
    {
        showAddModal = false;
        showConfirmAddModal = true;
        return Task.CompletedTask;
    }

    private Task CancelAddCustomer()
    {
        showAddModal = false;
        return Task.CompletedTask;
    }
}