@page "/admin/customer"
@layout STTproject.Shared.Layout.Admin.AdminSideBar
@using STTproject.Features.Admin.Customers.Components.Modals
@using STTproject.Features.Admin.Customers.Components.Sections
@using STTproject.Shared.Components

@if (isLoading)
{
    <div class="loading-overlay">
        <div class="loading-bar-track">
            <div class="loading-bar-fill"></div>
        </div>
        <p>Loading customers…</p>
    </div>
}

<div style="@(isLoading ? "display:none;" : "")">
    <div class="clt-page">
        @* ------------- Header ----------------- *@
        <div class="clt-page-header">
            <div>
                <h1 class="clt-page-title">Customers</h1>
                <p class="clt-page-sub">@totalCount total customers</p>
            </div>
            <button class="clt-add-btn" @onclick="OpenAddCustomerModal">
                <span class="clt-add-icon">+</span> Add customer
            </button>
        </div>

        @* ------------- Customer List Table ----------------- *@
        <CustomerListTable @ref="customerTable" OnLoaded="OnTableLoaded" OnCountChanged="OnCountChanged"
                           OnViewCustomer="OpenEditModal" />

        <ConfirmModal @ref="confirmAddModal" Show="showConfirmAddModal"
                      Title="@(editCustomerId.HasValue ? "Confirm Update of Customer" : "Confirm Creation of Customer")"
                      Message="@(editCustomerId.HasValue ? "Are you sure you want to save changes to this customer?" : "Are you sure you want to create this customer?")"
                      OnYes="ConfirmAddCustomer" OnNo="CancelConfirm" />

        @if (showAddModal)
        {
            <AddCustomer @ref="addCustomerModal" CustomerId="editCustomerId" onCancel="CancelAddCustomer"
                         OnRequestConfirm="OpenConfirmModal" />
        }

    </div>
</div>

@code {
    private ConfirmModal? confirmAddModal;
    private bool showConfirmAddModal;
    private bool showAddModal;
    private bool isLoading = true;
    private int totalCount = 0;
    private CustomerListTable? customerTable;
    private AddCustomer? addCustomerModal;

    private async Task OnTableLoaded()
    {
        isLoading = false;
        await InvokeAsync(StateHasChanged);
    }
    private int? editCustomerId;

    private void OpenAddCustomerModal()
    {
        editCustomerId = null; // new customer
        showAddModal = true;
    }

    // called from CustomerListTable OnViewCustomer
    private void OpenEditModal(int id)
    {
        editCustomerId = id;
        showAddModal = true;
    }

    private void OnCountChanged(int count) => totalCount = count;

    private void OpenConfirmModal() => showConfirmAddModal = true;

    private void CancelConfirm() => showConfirmAddModal = false;

    private void CancelAddCustomer() => showAddModal = false;

    private async Task ConfirmAddCustomer()
    {
        showConfirmAddModal = false;

        if (addCustomerModal == null) return;

        var (success, _) = await addCustomerModal.SubmitAsync();

        if (success)
        {
            showAddModal = false;
            if (customerTable != null)
                await customerTable.LoadPageAsync();
        }
        // if not success, confirm closes but form stays open showing the error
    }
}