@using STTproject.Features.User.SalesInvoice.Services

<div class="modal @(Show ? "show" : "")"
     style="@(Show ? "display: block; background-color: rgba(0,0,0,0.5);" : "display: none;")">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Import Results</h5>
            </div>
            <div class="modal-body" style="max-height: 60vh; overflow-y: auto;">
                @if (ImportResult == null)
                {
                    <p>No import result to display.</p>
                }
                else
                {
                    var invoiceCards = GetInvoiceCards();
                    var globalIssues = GetGlobalIssues();
                    var hasSuccessCards = invoiceCards.Any(card => !card.HasErrors);
                    var hasErrorCards = invoiceCards.Any(card => card.HasErrors);
                    var filteredCards = GetFilteredCards(invoiceCards);
                    var selectedCount = invoiceCards.Count(card => card.Prepared?.Selected == true && !card.HasErrors &&
                card.Prepared?.IsSaved != true);
                    var selectableCount = invoiceCards.Count(card => card.Prepared != null && !card.HasErrors &&
                card.Prepared.IsSaved != true);

                    if (globalIssues.Any())
                    {
                        <div class="alert alert-danger">
                            <strong>Import Failed</strong>
                            <ul class="mb-0 mt-2">
                                @foreach (var issue in globalIssues)
                                {
                                    <li>
                                        <small class="text-muted">Row @issue.RowNumber</small>
                                        <span>: @issue.Message</span>
                                    </li>
                                }
                            </ul>
                        </div>
                    }

                    if (!invoiceCards.Any() && !globalIssues.Any())
                    {
                        <div class="alert alert-success">
                            <strong>Import Successful!</strong>
                            <p>@ImportResult.ImportedInvoiceCount invoice(s) imported with @ImportResult.ImportedRowCount total
                                row(s).</p>
                            </div>
                        }

                        @if (invoiceCards.Any())
                        {
                            <div class="d-flex gap-2 mb-3">
                                <div class="d-flex align-items-center me-2">
                                    @if (cardFilter == InvoiceCardFilter.SuccessOnly && selectableCount > 0)
                                    {
                                        <div class="form-check d-flex align-items-center me-2">
                                            <input class="form-check-input me-2" type="checkbox"
                                                   checked="@(selectedCount == selectableCount)"
                                                   @onchange="(e) => ToggleSelectAllInvoices(e.Value)" />
                                            <label class="form-check-label">Select All (@selectedCount/@selectableCount)</label>
                                        </div>
                                    }

                                     @if (cardFilter == InvoiceCardFilter.ErrorOnly && hasErrorCards)
                                    {
                                        <div class="d-flex align-items-center">
                                            <label class="me-2">Errors: @GetTotalErrorCount()</label>
<div class="form-group">
                                            <select
                                                    @onchange="OnErrorFilterChanged" value="@(selectedErrorFilter ?? string.Empty)">
                                                <option value="">All errors</option>
                                                @foreach (var entry in GetDistinctErrorMessages())
                                                {
                                                    var display = entry.Message.Length > 120 ? entry.Message.Substring(0, 117) + "..." : entry.Message;
                                                    <option value="@entry.Message">@display (@entry.Count)</option>
                                                }
                                            </select>
</div>
                                            @if (!string.IsNullOrEmpty(selectedErrorFilter))
                                            {
                                                <button type="button" class="btn btn-link btn-sm ms-2 p-0" @onclick="ClearErrorFilter">Clear</button>
                                            }
                                        </div>
                                    }
                                </div>

                                @if (hasSuccessCards)
                                {
                                    <button type="button"
                                            class="btn @(cardFilter == InvoiceCardFilter.SuccessOnly ? "btn-success" : "btn-outline-success")"
                                            @onclick="ToggleSuccessOnly">
                                        Success Only
                                    </button>
                                }

                                @if (hasErrorCards)
                                {
                                    <button type="button"
                                            class="btn @(cardFilter == InvoiceCardFilter.ErrorOnly ? "btn-danger" : "btn-outline-danger")"
                                            @onclick="ToggleErrorOnly">
                                        Error Only
                                    </button>
                                }
                            </div>

                            <div class="import-results">
                                @if (IsCustomerErrorFilterActive())
                                {
                                    var customerCards = GetCustomerErrorCards(invoiceCards);

                                    foreach (var customerCard in customerCards)
                                    {
                                        <div class="card mb-3 border-warning">
                                            <div class="card-header d-flex justify-content-between align-items-center bg-warning text-dark">
                                                <div>
                                                    <h6 class="mb-0">Customer code/name: <strong>@customerCard.CustomerValue</strong></h6>
                                                </div>
                                            </div>
                                            <div class="card-body">
                                                <div>
                                                    <small class="text-muted">Rows:</small> @customerCard.RowNumbers
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                                else if (IsSkuErrorFilterActive())
                                {
                                    var skuCards = GetSkuErrorCards(invoiceCards);

                                    foreach (var skuCard in skuCards)
                                    {
                                        <div class="card mb-3 border-warning">
                                            <div class="card-header d-flex justify-content-between align-items-center bg-warning text-dark">
                                                <div>
                                                    <h6 class="mb-0">SKU code: <strong>@skuCard.SkuValue</strong></h6>
                                                </div>
                                            </div>
                                            <div class="card-body">
                                                <div><code>Rows: @skuCard.RowNumbers</code></div>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    @foreach (var card in filteredCards)
                                    {
                                        <div class="card mb-3 @(card.HasErrors ? "border-danger" : "border-success")">
                                            <div
                                                class="card-header d-flex justify-content-between align-items-center @(card.HasErrors ? "bg-danger text-white" : "bg-success text-white")">
                                                <div>
                                                    <h6 class="mb-0">Invoice: <strong>@card.InvoiceNumber</strong></h6>
                                                </div>
                                                <div>
                                                    @if (card.Prepared?.IsSaved == true)
                                                    {
                                                        <span class="badge bg-light text-success">Saved</span>
                                                    }
                                                    else if (card.HasErrors)
                                                    {
                                                        <span class="badge bg-light text-danger">@GetErrorBadgeText(card)</span>
                                                    }
                                                    else if (card.Prepared != null)
                                                    {
                                                        <input type="checkbox" @bind="card.Prepared.Selected" />
                                                    }
                                                </div>
                                            </div>
                                            <div class="card-body">
                                                @if (card.Prepared?.Invoice != null)
                                                {
                                                    <div class="mb-2">
                                                        <small class="text-muted">Date:</small> @card.Prepared.Invoice.InvoiceDate.ToString("d")
                                                        &nbsp; | &nbsp;
                                                        <small class="text-muted">Customer:</small> @card.Prepared.Invoice.CustomerCode -
                                                        @card.Prepared.Invoice.CustomerName &nbsp; | &nbsp;
                                                        <small class="text-muted">Order Type:</small> @card.Prepared.Invoice.OrderType &nbsp; |
                                                        &nbsp;
                                                        <small class="text-muted">Total Amount:</small> @card.Prepared.Items.Sum(item =>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            item.Amount).ToString("N2")
                                                    </div>
                                                }

                                                @if (card.Prepared?.Items != null && card.Prepared.Items.Count > 0)
                                                {
                                                    <table class="table table-sm">
                                                        <thead>
                                                            <tr>
                                                                <th>SKU</th>
                                                                <th>UOM</th>
                                                                <th class="text-end">Quantity</th>
                                                                <th class="text-end">Line Amount</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var it in card.Prepared.Items)
                                                            {
                                                                <tr>
                                                                    <td>@it.ItemCode</td>
                                                                    <td>@it.UomName</td>
                                                                    <td class="text-end">@it.Quantity</td>
                                                                    <td class="text-end">@it.Amount.ToString("N2")</td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                }

                                                @if (card.HasErrors)
                                                {
                                                    var visibleIssues = (card.Issues ?? new List<ImportSalesInvoiceIssue>())
                                                        .Concat(card.Prepared?.Issues ?? Enumerable.Empty<ImportSalesInvoiceIssue>());

                                                    if (!string.IsNullOrWhiteSpace(selectedErrorFilter))
                                                    {
                                                        visibleIssues = visibleIssues.Where(i => NormalizeSalesIssueType(i) == selectedErrorFilter);
                                                    }

                                                    var grouped = visibleIssues.GroupBy(i => i.RowNumber).OrderBy(g => g.Key).ToList();

                                                    if (grouped.Any())
                                                    {
                                                        <div class="mt-2">
                                                            <ul class="list-unstyled text-danger mb-0">
                                                                @foreach (var rowGroup in grouped)
                                                                {
                                                                    var rowNum = rowGroup.Key;
                                                                    var combined = string.Join("\n", rowGroup.Select(i => i.Message));
                                                                    <li>
                                                                        <small class="text-muted">Row @rowNum</small>
                                                                        <span style="white-space: pre-line;">: @combined</span>
                                                                    </li>
                                                                }
                                                            </ul>
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer">
                    @if (ImportResult != null && ImportResult.PreparedInvoices != null &&
                                                        ImportResult.PreparedInvoices.Count > 0)
                    {
                        <button type="button" class="btn btn-primary" disabled="@(!CanCommit)"
                                @onclick="OpenCommitConfirmModal">Commit Selected</button>
                    }
                    <button type="button" class="btn btn-secondary" @onclick="OnClose">Close</button>
                </div>
            </div>
        </div>
    </div>

<ConfirmModal Show="showCommitConfirmModal" Title="Commit Selected Invoices"
              Message="@($"Commit {GetSelectedInvoiceCount()} selected invoice(s)?")" OnYes="ConfirmCommit" OnNo="CancelCommit"
              CloseOnOverlayClick="true" />

@code {
    [Parameter]
    public bool Show { get; set; }

    [Parameter]
    public ImportSalesInvoiceResult? ImportResult { get; set; }

    [Parameter]
    public EventCallback OnCommit { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private InvoiceCardFilter cardFilter = InvoiceCardFilter.All;
    private bool showCommitConfirmModal;
    private string? selectedErrorFilter;

    private bool CanCommit => ImportResult != null && ImportResult.PreparedInvoices != null &&
        ImportResult.PreparedInvoices.Any(p => p.Selected && (p.Issues == null || p.Issues.Count == 0) && !p.IsSaved);

    private List<InvoiceCardViewModel> GetInvoiceCards()
    {
        if (ImportResult == null)
        {
            return new List<InvoiceCardViewModel>();
        }

        var cards = new List<InvoiceCardViewModel>();

        foreach (var prepared in ImportResult.PreparedInvoices ?? new List<PreparedInvoice>())
        {
            var matchingIssues = (prepared.Issues ?? new List<ImportSalesInvoiceIssue>())
                .GroupBy(issue => new { issue.RowNumber, issue.InvoiceNumber, issue.ColumnName, issue.Message })
                .Select(g => g.First())
                .OrderBy(issue => issue.RowNumber)
                .ThenBy(issue => issue.ColumnName)
                .ThenBy(issue => issue.Message)
                .ToList();

            cards.Add(new InvoiceCardViewModel(prepared.InvoiceNumber, prepared, matchingIssues));
        }

        var orphanIssues = (ImportResult.Issues ?? new List<ImportSalesInvoiceIssue>())
            .Where(issue => issue.RowNumber > 0)
            .GroupBy(issue => issue.RowNumber)
            .ToList();

        foreach (var group in orphanIssues)
        {
            var issues = group
                .GroupBy(issue => new { issue.RowNumber, issue.InvoiceNumber, issue.ColumnName, issue.Message })
                .Select(g => g.First())
                .OrderBy(issue => issue.RowNumber)
                .ThenBy(issue => issue.ColumnName)
                .ThenBy(issue => issue.Message)
                .ToList();

            var firstIssue = group.First();
            var displayInvoiceNumber = string.IsNullOrWhiteSpace(firstIssue.InvoiceNumber)
                ? "[Blank Invoice Code]"
                : firstIssue.InvoiceNumber;

            cards.Add(new InvoiceCardViewModel(displayInvoiceNumber, null, issues));
        }

        return cards
            .OrderBy(card => card.Issues.Count > 0 ? card.Issues.Min(issue => issue.RowNumber) : int.MaxValue)
            .ThenBy(card => card.InvoiceNumber)
            .ToList();
    }

    private List<ImportSalesInvoiceIssue> GetGlobalIssues()
    {
        if (ImportResult == null)
        {
            return new List<ImportSalesInvoiceIssue>();
        }

        return ImportResult.Issues
            .Concat((ImportResult.PreparedInvoices ?? new List<PreparedInvoice>())
                .SelectMany(prepared => prepared.Issues ?? new List<ImportSalesInvoiceIssue>()))
            .Where(issue => issue.RowNumber == 0)
            .OrderBy(issue => issue.RowNumber)
            .ThenBy(issue => issue.Message)
            .ToList();
    }

    private List<InvoiceCardViewModel> GetFilteredCards(List<InvoiceCardViewModel> cards)
    {
        return cardFilter switch
        {
            InvoiceCardFilter.SuccessOnly => cards.Where(card => !card.HasErrors).ToList(),
            InvoiceCardFilter.ErrorOnly => !string.IsNullOrWhiteSpace(selectedErrorFilter)
                ? cards.Where(card => CardContainsError(card, selectedErrorFilter)).ToList()
                : cards.Where(card => card.HasErrors).ToList(),
            _ => cards
        };
    }

    private void ToggleSuccessOnly()
    {
        cardFilter = cardFilter == InvoiceCardFilter.SuccessOnly
            ? InvoiceCardFilter.All
            : InvoiceCardFilter.SuccessOnly;
    }

    private void ToggleErrorOnly()
    {
        if (cardFilter == InvoiceCardFilter.ErrorOnly)
        {
            cardFilter = InvoiceCardFilter.All;
            selectedErrorFilter = null;
        }
        else
        {
            cardFilter = InvoiceCardFilter.ErrorOnly;
        }
    }

    private int GetSelectedInvoiceCount()
    {
        if (ImportResult?.PreparedInvoices == null)
        {
            return 0;
        }

        return ImportResult.PreparedInvoices.Count(prepared => prepared.Selected && !prepared.IsSaved && (prepared.Issues ==
null || prepared.Issues.Count == 0));
    }

    private int GetTotalErrorCount()
    {
        if (ImportResult == null)
        {
            return 0;
        }

        var cards = GetInvoiceCards();
        return cards.Sum(card => (card.Prepared?.Issues?.Count ?? 0) + card.Issues.Count);
    }

    private IEnumerable<(string Message, int Count)> GetDistinctErrorMessages()
    {
        var cards = GetInvoiceCards();
        var all = new List<string>();

        foreach (var card in cards)
        {
            if (card.Issues != null)
                all.AddRange(card.Issues.Select(i => NormalizeSalesIssueType(i)));

            if (card.Prepared?.Issues != null)
                all.AddRange(card.Prepared.Issues.Select(i => NormalizeSalesIssueType(i)));
        }

        return all.Where(m => !string.IsNullOrWhiteSpace(m))
            .GroupBy(m => m)
            .Select(g => (Message: g.Key, Count: g.Count()))
            .OrderByDescending(x => x.Count)
            .ThenBy(x => x.Message)
            .ToList();
    }

    private static string NormalizeMessage(string? m) => (m ?? string.Empty).Trim();

    private static string NormalizeMessageType(string? m)
    {
        var msg = NormalizeMessage(m).ToLowerInvariant();
        if (string.IsNullOrWhiteSpace(msg)) return string.Empty;

        if (msg.Contains("duplicat") && (msg.Contains("uploaded") || msg.Contains("excel")))
        {
            if (msg.Contains("subd") || msg.Contains("subditem") || msg.Contains("subdistributor"))
                return "SubdItem Duplicated In Excel";
            return "Duplicated In Excel";
        }
        if (msg.Contains("duplicate") && msg.Contains("uom")) return "Duplicate UOM";
        if (msg.Contains("duplicate") && msg.Contains("conversion")) return "Duplicate Conversion";
        if (msg.Contains("already mapped") || (msg.Contains("already") && msg.Contains("mapped"))) return "Already Mapped";
        if (msg.Contains("already exists") || msg.Contains("already exist") || msg.Contains("is already")) return "Already Exists";

        if (msg.Contains("duplicate") && msg.Contains("invoice")) return "Duplicate Invoice Code";
        if (msg.Contains("uom not found") || (msg.Contains("not found") && msg.Contains("uom"))) return "UOM Not Found";
        if (msg.Contains("invalid uom") || (msg.Contains("invalid") && msg.Contains("uom"))) return "Invalid UOM";
        if (msg.Contains("conversion mismatch") || (msg.Contains("mismatch") && msg.Contains("conversion"))) return "Conversion Mismatch";

        return NormalizeMessage(m);
    }

    private void OnErrorFilterChanged(ChangeEventArgs e)
    {
        selectedErrorFilter = e?.Value?.ToString();
    }

    private void ClearErrorFilter()
    {
        selectedErrorFilter = null;
    }

    private bool IsCustomerErrorFilterActive()
    {
        return cardFilter == InvoiceCardFilter.ErrorOnly &&
            string.Equals(selectedErrorFilter, "Customer Error", StringComparison.OrdinalIgnoreCase);
    }

    private bool IsSkuErrorFilterActive()
    {
        return cardFilter == InvoiceCardFilter.ErrorOnly &&
            string.Equals(selectedErrorFilter, "SKU Not Found", StringComparison.OrdinalIgnoreCase);
    }

    private List<SkuErrorCardViewModel> GetSkuErrorCards(List<InvoiceCardViewModel> cards)
    {
        var visibleIssues = cards
            .SelectMany(card => (card.Issues ?? new List<ImportSalesInvoiceIssue>())
                .Concat(card.Prepared?.Issues ?? Enumerable.Empty<ImportSalesInvoiceIssue>()))
            .Where(issue => NormalizeSalesIssueType(issue) == selectedErrorFilter)
            .ToList();

        return visibleIssues
            .GroupBy(issue => NormalizeSkuValue(issue.SkuValue))
            .Select(group => new SkuErrorCardViewModel(
                SkuValue: string.IsNullOrWhiteSpace(group.Key) ? "[Blank SKU]" : group.Key,
                RowNumbers: string.Join(", ", group.Select(issue => issue.RowNumber).Distinct().OrderBy(row => row))))
            .OrderBy(card => card.SkuValue)
            .ToList();
    }

    private List<CustomerErrorCardViewModel> GetCustomerErrorCards(List<InvoiceCardViewModel> cards)
    {
        var visibleIssues = cards
            .SelectMany(card => (card.Issues ?? new List<ImportSalesInvoiceIssue>())
                .Concat(card.Prepared?.Issues ?? Enumerable.Empty<ImportSalesInvoiceIssue>()))
            .Where(issue => NormalizeSalesIssueType(issue) == selectedErrorFilter)
            .ToList();

        return visibleIssues
			.GroupBy(issue => NormalizeCustomerValue(issue))
            .Select(group => new CustomerErrorCardViewModel(
				CustomerValue: string.IsNullOrWhiteSpace(group.Key) ? "[Blank Customer]" : group.Key,
                MissingData: string.Join("; ", group.Select(issue => issue.Message).Distinct()),
                RowNumbers: string.Join(", ", group.Select(issue => issue.RowNumber).Distinct().OrderBy(row => row))))
            .OrderBy(card => card.CustomerValue)
            .ToList();
    }

    private static string NormalizeCustomerValue(ImportSalesInvoiceIssue issue)
    {
        if (issue is null)
        {
            return string.Empty;
        }

        if (!string.IsNullOrWhiteSpace(issue.CustomerValue))
        {
            return issue.CustomerValue.Trim();
        }

        var extracted = ExtractQuotedValue(issue.Message);
        return string.IsNullOrWhiteSpace(extracted) ? string.Empty : extracted;
    }

    private static string ExtractQuotedValue(string? message)
    {
        if (string.IsNullOrWhiteSpace(message))
        {
            return string.Empty;
        }

        var firstQuote = message.IndexOf('\'');
        if (firstQuote < 0)
        {
            return string.Empty;
        }

        var secondQuote = message.IndexOf('\'', firstQuote + 1);
        if (secondQuote <= firstQuote + 1)
        {
            return string.Empty;
        }

        return message.Substring(firstQuote + 1, secondQuote - firstQuote - 1).Trim();
    }

    private static string NormalizeSkuValue(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? string.Empty : value.Trim();
    }

    private bool CardContainsError(InvoiceCardViewModel card, string? message)
    {
        if (string.IsNullOrWhiteSpace(message)) return false;
        var norm = message?.Trim() ?? string.Empty;

        if (card.Issues != null && card.Issues.Any(i => NormalizeSalesIssueType(i) == norm)) return true;
        if (card.Prepared?.Issues != null && card.Prepared.Issues.Any(i => NormalizeSalesIssueType(i) == norm)) return true;
        return false;
    }

    private static string NormalizeSalesIssueType(ImportSalesInvoiceIssue issue)
    {
        if (issue == null) return string.Empty;

        var col = (issue.ColumnName ?? string.Empty).Trim().ToLowerInvariant();
        var msg = NormalizeMessage(issue.Message).ToLowerInvariant();

        if (!string.IsNullOrWhiteSpace(col))
        {
            if (col.Contains("uom"))
            {
                if (msg.Contains("not found") || msg.Contains("missing")) return "UOM Not Found";
                if (msg.Contains("invalid")) return "Invalid UOM";
                return "UOM Error";
            }

            if (col.Contains("sku") || col.Contains("itemcode") || col.Contains("skucode"))
            {
                if (msg.Contains("not found") || msg.Contains("missing")) return "SKU Not Found";
                return "SKU Error";
            }

            if (col.Contains("quantity")) return "Quantity Error";
            if (col.Contains("amount") || col.Contains("netamount")) return "Amount Error";
            if (col.Contains("ordertype")) return "Order Type Missing";
            if (col.Contains("customercode") || col.Contains("customer")) return "Customer Error";
        }

        // fallback to message-based canonicalization
        var baseType = NormalizeMessageType(issue.Message);
        return baseType;
    }

    private void ToggleSelectAllInvoices(object? checkedValue)
    {
        if (checkedValue is not bool isChecked || ImportResult?.PreparedInvoices == null)
        {
            return;
        }

        foreach (var prepared in ImportResult.PreparedInvoices)
        {
            if (prepared.IsSaved || (prepared.Issues?.Count ?? 0) > 0)
            {
                continue;
            }

            prepared.Selected = isChecked;
        }
    }

    private void OpenCommitConfirmModal()
    {
        showCommitConfirmModal = true;
    }

    private void CancelCommit()
    {
        showCommitConfirmModal = false;
    }

    private async Task ConfirmCommit()
    {
        showCommitConfirmModal = false;
        await Commit();
    }

    private static string NormalizeInvoiceNumber(string value)
    {
        return string.IsNullOrWhiteSpace(value) ? "[Header Issue]" : value.Trim();
    }

    private string GetErrorBadgeText(InvoiceCardViewModel card)
    {
        int errorCount;
        if (string.IsNullOrWhiteSpace(selectedErrorFilter))
        {
            errorCount = card.Issues.Count > 0 ? card.Issues.Count : card.Prepared?.Issues?.Count ?? 0;
        }
        else
        {
            var visible = (card.Issues ?? new List<ImportSalesInvoiceIssue>())
                .Concat(card.Prepared?.Issues ?? Enumerable.Empty<ImportSalesInvoiceIssue>())
                .Count(i => NormalizeSalesIssueType(i) == selectedErrorFilter);
            errorCount = visible;
        }

        return errorCount == 1 ? "1 error" : $"{errorCount} errors";
    }

    private sealed record InvoiceCardViewModel(
        string InvoiceNumber,
        PreparedInvoice? Prepared,
        List<ImportSalesInvoiceIssue> Issues)
    {
        public bool HasErrors => Issues.Count > 0 || (Prepared?.Issues?.Count ?? 0) > 0;
    }

    private sealed record CustomerErrorCardViewModel(
        string CustomerValue,
        string MissingData,
        string RowNumbers);

    private sealed record SkuErrorCardViewModel(
        string SkuValue,
        string RowNumbers);

    private enum InvoiceCardFilter
    {
        All,
        SuccessOnly,
        ErrorOnly
    }

    private async Task Commit()
    {
        if (OnCommit.HasDelegate)
        {
            await OnCommit.InvokeAsync(null);
        }
    }
}
