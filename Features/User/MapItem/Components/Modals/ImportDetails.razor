@using STTproject.Features.User.MapItem.DTOs

<div class="modal @(Show ? "show" : "")"
     style="@(Show ? "display: block; background-color: rgba(0,0,0,0.5);" : "display: none;")">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Import Results</h5>
            </div>
            <div class="modal-body" style="max-height: 60vh; overflow-y: auto;">
                @if (ImportResult == null)
                {
                    <p>No import result to display.</p>
                }
                else if (!GetGlobalIssues().Any() && !ImportResult.Rows.Any())
                {
                    <div class="alert alert-warning">
                        <strong>No rows to import</strong>
                        <p>The import file did not contain any valid rows to process.</p>
                    </div>
                }
                else
                {
                    var globalIssues = GetGlobalIssues();
                    var groups = ImportResult.PreparedGroups ?? new List<PreparedItemGroup>();

                    foreach (var g in groups)
                    {
                        if (g.Rows.Any())
                        {
                            var key = BuildGroupKey(g.Rows.First());
                            g.Selected = SelectedGroupKeys.Contains(key);
                        }
                    }

                    var hasSuccessGroups = groups.Any(g => (g.Issues?.Count ?? 0) == 0 && g.Rows.All(r => r.Issues.Count ==
                0));
                    var hasErrorGroups = groups.Any(g => (g.Issues?.Count ?? 0) > 0 || g.Rows.Any(r => r.Issues.Count > 0));
                    var selectableCount = groups.Count(g => (g.Issues?.Count ?? 0) == 0 && g.Rows.All(r => r.Issues.Count ==
                0) && !g.IsSaved);
                    var selectedCount = groups.Count(g => g.Selected && !g.IsSaved && (g.Issues?.Count ?? 0) == 0 &&
                g.Rows.All(r => r.Issues.Count == 0));

                    if (globalIssues.Any())
                    {
                        <div class="alert alert-danger">
                            <strong>Import Failed</strong>
                            <ul class="mb-0 mt-2">
                                @foreach (var issue in globalIssues)
                                {
                                    <li>
                                        <small class="text-muted">Row @issue.RowNumber</small>
                                        <span>: @issue.Message</span>
                                    </li>
                                }
                            </ul>
                        </div>
                    }

                    <div class="d-flex gap-2 mb-3 align-items-center flex-wrap">
                        <div class="d-flex align-items-center me-2">
                            @if (groupFilter == GroupFilter.SuccessOnly && selectableCount > 0)
                            {
                                <div class="form-check d-flex align-items-center me-2">
                                    <input class="form-check-input me-2" type="checkbox"
                                           checked="@(selectedCount == selectableCount)"
                                           @onchange="(e) => ToggleSelectAllCards(e.Value)" />
                                    <label class="form-check-label">Select All (@selectedCount/@selectableCount)</label>
                                </div>
                            }

                            @if (groupFilter == GroupFilter.ErrorOnly && hasErrorGroups)
                            {
                                <div class="d-flex align-items-center">
                                    <label class="me-2">Errors: @GetTotalErrorCount()</label>
<div class="form-group">
                                    <select
                                            @onchange="OnErrorFilterChanged" value="@(selectedErrorFilter ?? string.Empty)">
                                        <option value="">All errors</option>
                                        @foreach (var entry in GetDistinctErrorMessages())
                                        {
                                            var display = entry.Message.Length > 120 ? entry.Message.Substring(0, 117) + "..." : entry.Message;
                                            <option value="@entry.Message">@display (@entry.Count)</option>
                                        }
                                    </select>
</div>
                                    @if (!string.IsNullOrEmpty(selectedErrorFilter))
                                    {
                                        <button type="button" class="btn btn-link btn-sm ms-2 p-0" @onclick="ClearErrorFilter">Clear</button>
                                    }
                                </div>
                            }
                        </div>

                        @if (hasSuccessGroups)
                        {
                            <button type="button"
                                    class="btn @(groupFilter == GroupFilter.SuccessOnly ? "btn-success" : "btn-outline-success")"
                                    @onclick="ToggleSuccessOnly">
                                Success Only
                            </button>
                        }

                        @if (hasErrorGroups)
                        {
                            <button type="button"
                                    class="btn @(groupFilter == GroupFilter.ErrorOnly ? "btn-danger" : "btn-outline-danger")"
                                    @onclick="ToggleErrorOnly">
                                Error Only
                            </button>
                        }
                    </div>

                    <div class="import-results">
                        @foreach (var group in groups
                            .Where(ShouldShowGroup)
                            .OrderBy(GetGroupSortKey))
                        {
                            var groupRows = group.Rows!;
                            var hasErrors = (group.Issues?.Count ?? 0) > 0 || groupRows.Any(r => r.Issues.Count > 0);
                            var first = groupRows.FirstOrDefault();
                            var displayName = first == null
                                ? "[Orphan]"
                                : (string.IsNullOrWhiteSpace(first.CompanyItemCode) ? "[Blank Item]" : $"{first.CompanyItemCode} -                    {first.CompanyItemName}");

                            <div class="card mb-3 @(hasErrors ? "border-danger" : "border-success")">
                                <div
                                    class="card-header d-flex justify-content-between align-items-center @(hasErrors ? "bg-danger text-white" : "bg-success text-white")">
                                    <div>
                                        <h6 class="mb-0">Company Item: <strong>@displayName</strong></h6>
                                    </div>
                                    <div>
                                        @if (group.IsSaved)
                                        {
                                            <span class="badge bg-light text-success">Saved</span>
                                        }
                                        else if (hasErrors)
                                        {
                                            var groupErrorCount = GetGroupErrorRowCount(group);
                                            <span class="badge bg-light text-danger">@((groupErrorCount == 1) ? "1 error" :$"{groupErrorCount} errors")</span>
                                            }
                                        else if (groupRows.Count > 0)
                                            {
                                                <input type="checkbox" checked="@group.Selected"
                                                       @onchange="(e) => ToggleGroupSelectionLocal(group, e.Value)" />
                                            }
                                        </div>
                                    </div>
                                    <div class="card-body">
                                        @if (first != null)
                                        {
                                            <div class="mb-2">
                                                <small class="text-muted">Principal:</small> @first.Principal &nbsp; | &nbsp;
                                                <small class="text-muted">Subdistributor:</small> @first.SubDistributorCode -
                                                @first.SubDistributorName &nbsp; |
                                                &nbsp;
                                                <small class="text-muted">Subdistributor Item:</small> @first.SubdItemCode -
                                                @first.SubdItemName
                                            </div>

                                            <table class="table table-sm">
                                                <thead>
                                                    <tr>
                                                        <th>Row</th>
                                                        <th>UOM</th>
                                                        <th>Conversion</th>
                                                        <th>Price</th>
                                                        <th>Status</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var row in groupRows.OrderBy(r => r.RowNumber))
                                                    {
                                                        <tr>
                                                            <td>@row.RowNumber</td>
                                                            <td>@row.UomName</td>
                                                            <td>@row.Conversion</td>
                                                            <td>@row.Price?.ToString("N2")</td>
                                                            <td>
                                                                @if (row.Issues.Count > 0)
                                                                {
                                                                    <span class="badge bg-danger">@((GetDisplayRowErrorCount(row) == 1) ? "1 error" : $"{GetDisplayRowErrorCount(row)} errors")</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="badge bg-success">Valid</span>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        }

                                        @{
                                            var visibleIssues = (group.Issues ?? new List<ImportMapItemIssue>())
                                                .Concat(groupRows.SelectMany(r => r.Issues.Select(i => new ImportMapItemIssue(r.RowNumber, r.SubdItemCode, i))));

                                            if (!string.IsNullOrWhiteSpace(selectedErrorFilter))
                                            {
                                                if (selectedErrorFilter == "SubdItem Duplicated In Excel")
                                                {
                                                    var matching = visibleIssues.Where(i => NormalizeMessageType(i.Message) == selectedErrorFilter).ToList();

                                                    // include other rows in the import that have the same SubdItemCode
                                                    var dupCodes = groupRows.Select(r => r.SubdItemCode).Where(s => !string.IsNullOrWhiteSpace(s)).Distinct(StringComparer.OrdinalIgnoreCase).ToList();
                                                    var extras = new List<ImportMapItemIssue>();
                                                    var allRows = ImportResult?.Rows ?? new List<ImportMapItemRowResult>();
                                                    foreach (var code in dupCodes)
                                                    {
                                                        var others = allRows.Where(rr => rr.RowNumber > 0 && !string.IsNullOrWhiteSpace(rr.SubdItemCode) && string.Equals(rr.SubdItemCode, code, StringComparison.OrdinalIgnoreCase)).ToList();
                                                        foreach (var other in others)
                                                        {
                                                            if (!groupRows.Any(r => r.RowNumber == other.RowNumber))
                                                            {
                                                                var msg = $"SubdItem code '{other.SubdItemCode}' is duplicated within the uploaded Excel for SubDistributor '{other.SubDistributorCode}'.";
                                                                extras.Add(new ImportMapItemIssue(other.RowNumber, other.SubdItemCode, msg));
                                                            }
                                                        }
                                                    }

                                                    visibleIssues = matching.Concat(extras);
                                                }
                                                else
                                                {
                                                    visibleIssues = visibleIssues.Where(i => NormalizeMessageType(i.Message) == selectedErrorFilter);
                                                }
                                            }

                                            var grouped = visibleIssues
                                                .GroupBy(i => new { i.RowNumber, i.Message })
                                                .Select(g => g.First())
                                                .GroupBy(i => i.RowNumber)
                                                .OrderBy(g => g.Key)
                                                .ToList();

                                            if (grouped.Any())
                                            {
                                                <div class="mt-2">
                                                    <ul class="list-unstyled text-danger mb-0">
                                                        @foreach (var rowGroup in grouped)
                                                        {
                                                            var rowNum = rowGroup.Key;
                                                            var combined = string.Join("\n\n", rowGroup.Select(i => i.Message));
                                                            <li>
                                                                <small class="text-muted">Row @rowNum</small>
                                                                <span style="white-space: pre-line;">: @combined</span>
                                                            </li>
                                                        }
                                                    </ul>
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    @if (ImportResult != null && GetSelectedCardCount() > 0)
                    {
                        <button type="button" class="btn btn-primary" disabled="@(!CanCommit)"
                                @onclick="OpenCommitConfirmModal">Commit Mapped Items</button>
                    }
                    <button type="button" class="btn btn-secondary" @onclick="HandleClose">Close</button>
                </div>
            </div>
        </div>
    </div>

@code {
    [Parameter]
    public bool Show { get; set; }

    [Parameter]
    public ImportMapItemResult? ImportResult { get; set; }

    [Parameter]
    public EventCallback OnCommit { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public HashSet<string> SelectedGroupKeys { get; set; } = new(StringComparer.OrdinalIgnoreCase);

    private bool showCommitConfirmModal;
    private bool wasShown;

    protected override void OnParametersSet()
    {
        if (Show && !wasShown)
        {
            groupFilter = GroupFilter.SuccessOnly;
            wasShown = true;
        }
        else if (!Show)
        {
            wasShown = false;
        }
    }

    private bool CanCommit => ImportResult != null && GetSelectedCardCount() > 0;

    private List<ImportMapItemIssue> GetGlobalIssues()
    {
        if (ImportResult == null)
        {
            return new List<ImportMapItemIssue>();
        }

        var headerIssues = ImportResult.Issues
            .Where(i => i.RowNumber == 0)
            .ToList();

        var rowHeaderIssues = ImportResult.Rows
            .Where(row => row.RowNumber == 0)
            .SelectMany(row => row.Issues.Select(issue => new ImportMapItemIssue(row.RowNumber, row.SubdItemCode, issue)))
            .ToList();

        var preparedHeaderIssues = ImportResult.PreparedGroups
            .SelectMany(g => g.Issues)
            .Where(i => i.RowNumber == 0)
            .ToList();

        return headerIssues
            .Concat(rowHeaderIssues)
            .Concat(preparedHeaderIssues)
            .GroupBy(i => new { i.RowNumber, i.SubdItemCode, i.Message })
            .Select(g => g.First())
            .ToList();
    }

    

    private GroupFilter groupFilter = GroupFilter.All;
    private string? selectedErrorFilter;

    private IEnumerable<(string Message, int Count)> GetDistinctErrorMessages()
    {
        if (ImportResult?.PreparedGroups == null)
            return Enumerable.Empty<(string, int)>();

        var all = new List<string>();
        foreach (var g in ImportResult.PreparedGroups)
        {
            if (g.Issues != null)
                all.AddRange(g.Issues.Select(i => NormalizeMessageType(i.Message)));

            if (g.Rows != null)
                all.AddRange(g.Rows.SelectMany(r => r.Issues.Select(i => NormalizeMessageType(i))));
        }

        return all
            .Where(m => !string.IsNullOrWhiteSpace(m))
            .GroupBy(m => m)
            .Select(g => (Message: g.Key, Count: g.Count()))
            .OrderByDescending(x => x.Count)
            .ThenBy(x => x.Message)
            .ToList();
    }

    private static string NormalizeMessage(string? m) => (m ?? string.Empty).Trim();

    private static string NormalizeMessageType(string? m)
    {
        var msg = NormalizeMessage(m).ToLowerInvariant();
        if (string.IsNullOrWhiteSpace(msg)) return string.Empty;

        // common canonicalizations
        if (msg.Contains("duplicate") && msg.Contains("uom")) return "Duplicate UOM";
        if (msg.Contains("duplicate") && msg.Contains("conversion")) return "Duplicate Conversion";
        if (msg.Contains("already exist") && msg.Contains("subd")) return "SubdItem Already Exists In Excel";
        // e.g. "Subditem code '82246' Item is duplicated within the uploaded Excel for SubDistributor '01GMA07'."
        if (msg.Contains("duplicat") && (msg.Contains("uploaded") || msg.Contains("excel")) && (msg.Contains("subd") || msg.Contains("subditem") || msg.Contains("subdistributor")))
            return "SubdItem Duplicated In Excel";

        if (msg.Contains("already mapped") || (msg.Contains("already") && msg.Contains("mapped"))) return "Already Mapped";

        if (msg.Contains("uom not found") || (msg.Contains("not found") && msg.Contains("uom"))) return "UOM Not Found";
        if (msg.Contains("invalid uom") || (msg.Contains("invalid") && msg.Contains("uom"))) return "Invalid UOM";
        if (msg.Contains("conversion mismatch") || (msg.Contains("mismatch") && msg.Contains("conversion"))) return "Conversion Mismatch";
        if (msg.Contains("uom is required") || msg.Contains("uom is missing")) return "UOM Required";
        if (msg.Contains("price is required") || msg.Contains("price missing")) return "Price Required";
        if (msg.Contains("conversion is required")) return "Conversion Required";

        // fallback: return original trimmed message
        return NormalizeMessage(m);
    }

    private void OnErrorFilterChanged(ChangeEventArgs e)
    {
        selectedErrorFilter = e?.Value?.ToString();
    }

    private void ClearErrorFilter()
    {
        selectedErrorFilter = null;
    }

    private void ToggleSuccessOnly()
    {
        groupFilter = groupFilter == GroupFilter.SuccessOnly ? GroupFilter.All : GroupFilter.SuccessOnly;
    }

    private void ToggleErrorOnly()
    {
        if (groupFilter == GroupFilter.ErrorOnly)
        {
            groupFilter = GroupFilter.All;
            selectedErrorFilter = null;
        }
        else
        {
            groupFilter = GroupFilter.ErrorOnly;
        }
    }

    private int GetSelectedCardCount()
    {
        if (ImportResult == null)
        {
            return 0;
        }
        var groups = ImportResult.PreparedGroups ?? new List<PreparedItemGroup>();
        return groups.Count(g => g.Rows.Any() && SelectedGroupKeys.Contains(BuildGroupKey(g.Rows.First())) && (g.Issues?.Count
?? 0) == 0 && g.Rows.All(r => r.Issues.Count == 0) && !g.IsSaved);
    }

    private int GetTotalErrorCount()
    {
        if (ImportResult == null)
        {
            return 0;
        }

        var groups = ImportResult.PreparedGroups ?? new List<PreparedItemGroup>();
        return groups.Sum(group => (group.Issues?.Count ?? 0) + group.Rows.Sum(row => row.Issues.Count));
    }

    private void ToggleSelectAllCards(object? checkedValue)
    {
        if (checkedValue is not bool isChecked || ImportResult == null)
        {
            return;
        }

        var groups = ImportResult.PreparedGroups ?? new List<PreparedItemGroup>();
        foreach (var g in groups)
        {
            if (g.Rows == null || g.Rows.Count == 0) continue;
            if ((g.Issues?.Count ?? 0) > 0) continue;
            var key = BuildGroupKey(g.Rows.First());
            if (isChecked)
            {
                SelectedGroupKeys.Add(key);
                g.Selected = true;
            }
            else
            {
                SelectedGroupKeys.Remove(key);
                g.Selected = false;
            }
        }
    }

    private enum GroupFilter
    {
        All,
        SuccessOnly,
        ErrorOnly
    }

    private static string BuildGroupKey(ImportMapItemRowResult row)
    {
        static string NormalizePart(string? value) => (value ?? string.Empty).Trim().ToUpperInvariant();
        return string.Join("|",
            NormalizePart(row.SubDistributorCode),
            NormalizePart(row.CompanyItemCode),
            NormalizePart(row.CompanyItemName));
    }

    private void OpenCommitConfirmModal()
    {
        showCommitConfirmModal = true;
    }

    private void CancelCommit()
    {
        showCommitConfirmModal = false;
    }

    private async Task ConfirmCommit()
    {
        showCommitConfirmModal = false;
        await HandleCommit();
    }

    private async Task HandleCommit()
    {
        if (OnCommit.HasDelegate)
        {
            await OnCommit.InvokeAsync(null);
        }
    }

    private async Task HandleClose()
    {
        if (OnClose.HasDelegate)
        {
            await OnClose.InvokeAsync(null);
        }
    }

    private void ToggleGroupSelectionLocal(PreparedItemGroup? prepared, object? checkedValue)
    {
        if (prepared == null || checkedValue is not bool isChecked) return;

        if (prepared.Rows.Any())
        {
            var key = BuildGroupKey(prepared.Rows.First());
            if (isChecked)
            {
                SelectedGroupKeys.Add(key);
            }
            else
            {
                SelectedGroupKeys.Remove(key);
            }
        }
    }

    private bool ShouldShowGroup(PreparedItemGroup group)
    {
        var rows = group.Rows;
        var hasRowIssues = rows.Any(r => r.Issues.Count > 0);
        var hasGroupIssues = (group.Issues?.Count ?? 0) > 0;
        return groupFilter switch
        {
            GroupFilter.SuccessOnly => !hasGroupIssues && !hasRowIssues,
            GroupFilter.ErrorOnly => !string.IsNullOrWhiteSpace(selectedErrorFilter)
                ? GroupContainsError(group, selectedErrorFilter)
                : (hasGroupIssues || hasRowIssues),
            _ => true
        };
    }

    private bool GroupContainsError(PreparedItemGroup group, string? message)
    {
        if (string.IsNullOrWhiteSpace(message)) return false;
        var norm = NormalizeMessageType(message);

        if (group.Issues != null && group.Issues.Any(i => NormalizeMessageType(i.Message) == norm)) return true;
        if (group.Rows != null && group.Rows.Any(r => r.Issues.Any(i => NormalizeMessageType(i) == norm))) return true;
        return false;
    }

    private static int GetGroupSortKey(PreparedItemGroup group)
    {
        var rows = group.Rows;
        return rows.Count > 0 ? rows.Min(r => r.RowNumber) : int.MaxValue;
    }

    private int GetDisplayRowErrorCount(ImportMapItemRowResult row)
    {
        if (string.IsNullOrWhiteSpace(selectedErrorFilter)) return row.Issues.Count;
        return row.Issues.Count(i => NormalizeMessageType(i) == selectedErrorFilter);
    }

    private int GetGroupErrorRowCount(PreparedItemGroup group)
    {
        var affectedRows = new HashSet<int>();

        // rows' issues
        foreach (var row in group.Rows.Where(r => r.Issues.Count > 0))
        {
            if (string.IsNullOrWhiteSpace(selectedErrorFilter))
            {
                affectedRows.Add(row.RowNumber);
            }
            else
            {
                if (row.Issues.Any(i => NormalizeMessageType(i) == selectedErrorFilter))
                    affectedRows.Add(row.RowNumber);
            }
        }

        if (group.Issues != null)
        {
            foreach (var issue in group.Issues)
            {
                if (issue.RowNumber > 0)
                {
                    if (string.IsNullOrWhiteSpace(selectedErrorFilter) || NormalizeMessageType(issue.Message) == selectedErrorFilter)
                        affectedRows.Add(issue.RowNumber);
                }
            }

            if (group.Issues.Any(issue => issue.RowNumber == 0 && (string.IsNullOrWhiteSpace(selectedErrorFilter) || NormalizeMessageType(issue.Message) == selectedErrorFilter)))
            {
                return affectedRows.Count + 1;
            }
        }

        return affectedRows.Count;
    }
}


<ConfirmModal Show="showCommitConfirmModal" Title="Commit Selected Items"
              Message="@($"Commit {GetSelectedCardCount()} selected item(s)?")" OnYes="ConfirmCommit" OnNo="CancelCommit"
              CloseOnOverlayClick="true" />
