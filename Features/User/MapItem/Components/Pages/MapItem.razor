@page "/mapitem"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components
@using STTproject.Services
@using STTproject.Shared.Components
@using STTproject.Features.User.MapItem.Components.Sections
@using STTproject.Features.User.MapItem.Components.Modals
@implements IAsyncDisposable
@inject NavigationManager Navigation
@inject IHomeService homeService
@inject IMapItemService mapItemService
@inject IUserContextService userContext
@inject IJSRuntime JS
@inject STTproject.Features.User.MapItem.Services.DownloadTemplateService downloadTemplateService
@inject STTproject.Features.User.MapItem.Services.ImportMapItemService importMapItemService
@inject STTproject.Features.User.MapItem.Services.MapItemDraftService draftService

<div>
    <!-- SUB DISTRIBUTOR + SEARCH + LOCATION -->
    <button class="btn-secondary" @onclick="GoBackToHome" title="Press Esc to go back">
        <i class="fa-solid fa-arrow-left"></i> Back
    </button>

    <div class="header-with-search">
        <h3 class="header-title"><b>SUB DISTRIBUTORS</b></h3>
        <select class="search-input" @ref="subdSelectRef" @bind="selectedSubdId" @bind:after="OnSubdChangedAsync"
                @onkeydown="HandleSubdKeyDown">
            <option value="0">-- Select Sub Distributor --</option>
            @foreach (var subd in subdList)
            {
                <option value="@subd.SubDistributorId">@subd.SubdName</option>
            }
        </select>
        <div class="location badge">
            LOCATION: <span>@locationText</span>
        </div>
    </div>

    <!-- DOWNLOAD TEMPLATE + IMPORT -->
    <div class="top-buttons">
        <button class="btn-primary" @onclick="() => showDownloadTemplateModal = true">Download Template</button>
        <button class="btn-primary" @onclick="ShowImportConfirmModal">Import Excel</button>
        <InputFile id="mapitem-import-file" class="d-none" accept=".xlsx" OnChange="HandleImportFileSelected" />
    </div>

    <MapItemInputHeader @ref="mapItemInputHeader" IsSubDistributorSelected="@IsSubDistributorSelected"
                        IsEditingItem="@IsEditingItem" CanOpenAddUom="@(IsSubDistributorSelected && selectedCompanyItemId.HasValue)"
                        CanSaveItem="@(IsSubDistributorSelected && uomEntries.Any())" ItemCode="@itemCode"
                        ItemCodeChanged="@(value => itemCode = value)" OnItemCodeChanged="HandleItemCodeChanged" ItemName="@itemName"
                        ItemNameChanged="@(value => itemName = value)" OnItemNameChanged="HandleItemNameChanged"
                        SelectedDropdownPrincipal="@selectedDropdownPrincipal"
                        SelectedDropdownPrincipalChanged="@(value => selectedDropdownPrincipal = value)"
                        OnPrincipalChanged="OnPrincipalChanged" DisplayPrincipalsDropdown="@DisplayPrincipalsDropdown"
                        CompanyItemsForDropdown="@FilteredCompanyItemsForDropdown.ToList()"
                        SelectedCompanyItemDisplayName="@selectedCompanyItemDisplayName"
                        SelectedCompanyItemDisplayNameChanged="@(value => selectedCompanyItemDisplayName = value)"
                        OnCompanyItemValueChanged="OnCompanyItemValueChanged" OnAutocompleteSelected="OnAutocompleteSelected"
                        OnCompanyItemConfirmed="OnCompanyItemConfirmed" GetFieldError="GetFieldError"
                        GetUnitOfMeasureSummary="GetUnitOfMeasureSummary" OnFormFieldBlur="HandleFormFieldBlur"
                        OnItemCodeKeyDown="HandleItemCodeKeyDown" OnItemNameKeyDown="HandleItemNameKeyDown"
                        OnPrincipalKeyDown="HandlePrincipalKeyDown" OnOpenAddUomModal="OpenAddUomModal" OnSaveItem="SaveItemAsync"
                        OnClearDraftRequested="ShowClearConfirmModal" OnCancelEdit="CancelEditAsync" />

    <!-- DASHBOARD PANELS -->
    <div class="dashboard">
        <PrincipalTable Principals="@principals" SelectedPrincipal="@selectedPrincipal"
                        SelectedPrincipalChanged="@(p => selectedPrincipal = p)" OnPrincipalSelected="FilterByPrincipalAsync" />
        <CompanyItemsTable IsSubDistributorSelected="@IsSubDistributorSelected"
                           CompanyItemCategories="@CompanyItemCategories.ToList()" CompanyItems="@companyItems"
                           SelectedCompanyItemsCategoryString="@selectedCompanyItemsCategoryString"
                           SelectedCompanyItemsCategoryStringChanged="@(value => selectedCompanyItemsCategoryString = value)"
                           OnCompanyItemsCategoryChanged="OnCompanyItemsCategoryChanged"
                           SelectedCompanyItemsFilterString="@selectedCompanyItemsFilterString"
                           SelectedCompanyItemsFilterStringChanged="@(value => selectedCompanyItemsFilterString = value)"
                           OnCompanyItemsFilterStringChanged="OnCompanyItemsFilterStringChanged"
                           SelectedCompanyItemIdForFilter="@selectedCompanyItemIdForFilter"
                           SelectedCompanyItemIdForFilterChanged="@(value => selectedCompanyItemIdForFilter = value)"
                           OnCompanyItemRowClicked="OnCompanyItemRowClicked" OnClearCompanyItemFilter="ClearCompanyItemFilterAsync" />
        <SubdItemTable IsSubDistributorSelected="@IsSubDistributorSelected" CompanyItems="@companyItems"
                       SubdItems="@filteredSubDistributorItems" SelectedCompanyItemIdForFilter="@selectedCompanyItemIdForFilter"
                       SelectedCompanyItemIdForFilterChanged="@(value => selectedCompanyItemIdForFilter = value)"
                       OnEditItem="BeginEditItem" OnDeleteItem="DeleteItemAsync"
                       OnClearCompanyItemFilter="ClearCompanyItemFilterAsync" />
    </div>

    @if (showConfirmModal)
    {
        <ConfirmModal Show="showConfirmModal" Title="@modalTitle" Message="@modalMessage" OnYes="ConfirmAction"
                      OnNo="CancelConfirmation">
            @if (!string.IsNullOrWhiteSpace(confirmedCompanyItemSummary))
            {
                <div class="modal-help">
                    <div><strong>SKU:</strong> @itemCode</div>
                    <div><strong>Item Name:</strong> @itemName</div>
                    <div><strong>Principal:</strong> @selectedDropdownPrincipal</div>
                    <div><strong>Company Item:</strong> @confirmedCompanyItemSummary</div>
                </div>
            }
        </ConfirmModal>
    }

    @if (showClearConfirmModal)
    {
        <ConfirmModal Show="showClearConfirmModal" Title="Clear Draft"
                      Message="Clear all unsaved changes for this sub-distributor?" OnYes="ConfirmClearDraft"
                      OnNo="CancelClearConfirm" />
    }

    <ConfirmModal Show="showImportConfirmModal" Title="Import Map Items"
                  Message="Import map item rows from the selected Excel file?" OnYes="ConfirmImport" OnNo="CancelImport" />

    <ConfirmModal Show="showErrorModal" Title="Error" ErrorMessage="@itemActionErrorMessage" ShowError="true"
                  OnErrorConfirm="CloseErrorModal" />

    <DownloadTemplate ShowModal="showDownloadTemplateModal" SubdList="subdList" PrincipalList="principals"
                      OnDownload="HandleDownloadTemplateSubmit" OnCancel="HandleDownloadTemplateCancel" />
    <ImportDetails Show="showImportDetailsModal" ImportResult="lastImportResult"
                   SelectedGroupKeys="selectedImportItemGroupKeys" OnCommit="HandleCommitImportAsync"
                   OnClose="CloseImportDetailsModal" />
    <AddUom ShowAddUomModal="@showAddUomModal" ExistingUomEntries="uomEntries"
            DraftStorageKey="@GetAddUomDraftStorageKey()" OnAdd="HandleAddUomModalAddAsync" OnCancel="CloseAddUomModalAsync"
            ItemCode="@modalCompanyItemCode" ItemName="@modalCompanyItemName" />
</div>
