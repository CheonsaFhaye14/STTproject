<div class="card-section">
    <div>
        <h3 class="company-items-title">
            COMPANY ITEMS
            @if (SelectedCompanyItemIdForFilter.HasValue)
            {
                var selectedItem = CompanyItems.FirstOrDefault(x => x.CompanyItemId == SelectedCompanyItemIdForFilter);
                <button @onclick="ClearFilterAsync" class="btn-secondary">
                    Clear Filter
                </button>
            }
        </h3>

    </div>
    <div class="filters">         
        <div class="filter-group">
                <input type="text" placeholder="Search"
                         @bind="SearchText" @bind:event="oninput" />
         </div>
        <div class="filter-group">
            <select @bind="SelectedCompanyItemsCategoryString" @bind:after="HandleCategoryChanged">
                <option value="All">All categories</option>
                @foreach (var category in CompanyItemCategories)
                {
                    <option value="@category">@category</option>
                }
            </select>
        </div>
        <div class="filter-group">
            <select @bind="SelectedCompanyItemsFilterString" @bind:after="HandleFilterChanged"
                    disabled="@(!IsSubDistributorSelected)">
                <option value="All">All company items</option>
                <option value="Unmapped">Items for Mapping </option>
                <option value="Mapped">Already Mapped</option>
            </select>
        </div></div>
    <table class="mapping-table">
        <thead>
            <tr>
                <th @onclick="() => SetSortByColumnAsync(CompanyItemSortColumn.CompanyItemCode)">COMPANY ITEM CODE @GetSortIndicator(CompanyItemSortColumn.CompanyItemCode)</th>
                <th @onclick="() => SetSortByColumnAsync(CompanyItemSortColumn.Category)">CATEGORY @GetSortIndicator(CompanyItemSortColumn.Category)</th>
                <th @onclick="() => SetSortByColumnAsync(CompanyItemSortColumn.ItemName)">ITEM NAME @GetSortIndicator(CompanyItemSortColumn.ItemName)</th>
            </tr>
        </thead>
        <tbody>
                @if (FilteredCompanyItems.Any())
            {
                    @foreach (var item in FilteredCompanyItems)
                {
                    var isSelected = SelectedCompanyItemIdForFilter == item.CompanyItemId;
                    var isPriceIncreaseScheduled = item.EffectivityDate.HasValue && item.EffectivityDate.Value > DateTime.Now;
                    var isMapped = item.IsMapped;
                    <tr @onclick="() => HandleRowClicked(item)"
                        class="company-items-row @(isSelected ? "selected-row" : string.Empty) @(isMapped ? "mapped-row" : string.Empty)">
                        <td>@item.CompanyItemCode</td>
                        <td>@(string.IsNullOrWhiteSpace(item.Category) ? "No category found" : item.Category)</td>
                        <td>
                            <div style="display: flex; flex-direction: column; gap: 4px;">
                                <span>@item.ItemName</span>
                                @if (isPriceIncreaseScheduled)
                                {
                                    <span class="badge bg-warning text-dark" style="align-self: flex-start;">
                                        Price increase scheduled on @item.EffectivityDate?.ToString("MMM dd, yyyy")
                                        @if (item.PriceIncreasePercent.HasValue)
                                        {
                                            <span>@($" (+{item.PriceIncreasePercent.Value:N2}%)")</span>
                                        }
                                    </span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="3">No company items match the current filters.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
