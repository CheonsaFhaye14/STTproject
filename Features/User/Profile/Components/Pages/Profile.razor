@page "/profile"
@rendermode InteractiveServer

<div class="profile-container">
    <div class="profile-header">
        <h1><i class="fa-solid fa-user-circle"></i> User Profile</h1>
        @if (CurrentUser != null && !IsEditMode)
        {
            <button type="button" class="btn-primary" @onclick="EnableEditMode" title="Edit profile">
                <i class="fa-solid fa-pen-to-square"></i> Edit Profile
            </button>
        }
    </div>

    @if (IsLoading)
    {
        <div class="loading-state">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p>Loading profile...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger">
            <i class="fa-solid fa-circle-exclamation"></i> @ErrorMessage
        </div>
    }
    else if (!string.IsNullOrEmpty(SuccessMessage))
    {
        <div class="alert alert-success">
            <i class="fa-solid fa-check-circle"></i> @SuccessMessage
        </div>
    }
    else if (CurrentUser != null)
    {
        <div class="profile-card">
            @if (IsEditMode)
            {
                <div class="modal-overlay" @onclick="CancelEdit">
                    <div class="modal-content" @onclick:stopPropagation="true">
                        <div class="modal-header">
                            <h4>Edit Profile</h4>
                            <button class="btn-close" @onclick="CancelEdit" title="Close">&times;</button>
                        </div>
                        <div class="modal-body">
                            <EditProfile EditingUser="EditingUser" OnSave="SaveChangesAsync" OnCancel="CancelEdit" />
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="view-mode">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="detail-section">
                                <h5 class="section-title"><i class="fa-solid fa-info-circle"></i> Basic Information</h5>
                                <div class="detail-item">
                                    <label class="detail-label">Username:</label>
                                    <span class="detail-value">@CurrentUser.Username</span>
                                </div>
                                <div class="detail-item">
                                    <label class="detail-label">Full Name:</label>
                                    <span class="detail-value">@CurrentUser.FullName</span>
                                </div>
                                <div class="detail-item">
                                    <label class="detail-label">Email:</label>
                                    <span class="detail-value">@(string.IsNullOrEmpty(CurrentUser.Email) ? "Not provided" :
                                                                                                                                                                                                                                                                                                                        CurrentUser.Email)</span>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="detail-section">
                                    <h5 class="section-title"><i class="fa-solid fa-shield"></i> Access & Status</h5>
                                    <div class="detail-item">
                                        <label class="detail-label">Role:</label>
                                        <span class="detail-value">
                                            <span class="badge bg-violet">@CurrentUser.Role</span>
                                        </span>
                                    </div>
                                    <div class="detail-item">
                                        <label class="detail-label">Status:</label>
                                        <span class="detail-value">
                                            <span class="@GetStatusClass(CurrentUser.IsActive)">
                                                @GetStatusBadge(CurrentUser.IsActive)
                                            </span>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="detail-section">
                                    <h5 class="section-title"><i class="fa-solid fa-calendar-plus"></i> Created</h5>
                                    <div class="detail-item">
                                        <label class="detail-label">Date:</label>
                                        <span class="detail-value">@FormatDate(CurrentUser.CreatedDate)</span>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="detail-section">
                                    <h5 class="section-title"><i class="fa-solid fa-calendar-check"></i> Last Updated</h5>
                                    <div class="detail-item">
                                        <label class="detail-label">Date:</label>
                                        <span class="detail-value">@FormatDate(CurrentUser.UpdatedDate)</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="action-buttons">
                            <ChangePass UserId="CurrentUser.UserId" />
                        </div>
                    </div>
                }
            </div>
        }
    else
        {
            <div class="alert alert-warning">
                <i class="fa-solid fa-triangle-exclamation"></i> No user data available.
            </div>
        }
    </div>
