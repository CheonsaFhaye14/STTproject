@page "/profile"
@rendermode InteractiveServer

<div class="profile-container">

    @if (IsLoading)
    {
        <div class="loading-overlay">
            <div class="loading-bar-track">
                <div class="loading-bar-fill"></div>
            </div>
            <p>Loading profile...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger">
            <i class="fa-solid fa-circle-exclamation"></i> @ErrorMessage
        </div>
    }
    else if (CurrentUser != null)
    {
        @if (!string.IsNullOrEmpty(SuccessMessage))
        {
            <div class="alert alert-success">
                <i class="fa-solid fa-check-circle"></i> @SuccessMessage
            </div>
        }

        <div class="profile-header">
            <h1>User Profile</h1>
            <button type="button" class="btn-edit-profile" @onclick="EnableEditMode">
                <i class="fa-solid fa-pen-to-square"></i> Edit Profile
            </button>
        </div>

        <div class="profile-card">

            @* Avatar banner *@
            <div class="card-banner">
                <div class="avatar">@GetInitials(CurrentUser.FullName)</div>
                <div class="banner-info">
                    <p class="banner-name">@CurrentUser.FullName</p>
                    <p class="banner-sub">
                        @CurrentUser.Role
                        <span class="status-pill @(CurrentUser.IsActive ? "pill-active" : "pill-inactive")">
                            <span class="dot"></span>
                            @GetStatusBadge(CurrentUser.IsActive)
                        </span>
                    </p>
                </div>
            </div>

            @* Field rows *@
            <div class="fields">
                <div class="field-row">
                    <span class="field-label"><i class="fa-solid fa-at"></i> Username</span>
                    <span class="field-value">@CurrentUser.Username</span>
                </div>
                <div class="field-row">
                    <span class="field-label"><i class="fa-solid fa-user"></i> Full Name</span>
                    <span class="field-value">@CurrentUser.FullName</span>
                </div>
                <div class="field-row">
                    <span class="field-label"><i class="fa-solid fa-envelope"></i> Email</span>
                    <span class="field-value">@(string.IsNullOrEmpty(CurrentUser.Email) ? "Not provided" : CurrentUser.Email)</span>
                </div>
                <div class="field-row">
                    <span class="field-label"><i class="fa-solid fa-shield"></i> Role</span>
                    <span class="field-value">@CurrentUser.Role</span>
                </div>
                <div class="field-row">
                    <span class="field-label"><i class="fa-solid fa-calendar-plus"></i> Created</span>
                    <span class="field-value muted">@FormatDate(CurrentUser.CreatedDate)</span>
                </div>
                <div class="field-row">
                    <span class="field-label"><i class="fa-solid fa-clock"></i> Last Updated</span>
                    <span class="field-value muted">@FormatDate(CurrentUser.UpdatedDate)</span>
                </div>
            </div>

            @* Footer *@
            <div class="card-footer">
                <ChangePass UserId="CurrentUser.UserId" />
            </div>

        </div>

        @* Edit modal *@
        @if (IsEditMode)
        {
            <div class="modal-overlay" @onclick="CancelEdit">
                <div class="modal-content" @onclick:stopPropagation="true">
                    <div class="modal-header">
                        <h4>Edit Profile</h4>
                       
                    </div>
                    <div class="modal-body">
                        <EditProfile EditingUser="EditingUser" OnSave="SaveChangesAsync" OnCancel="CancelEdit" />
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-warning">
            <i class="fa-solid fa-triangle-exclamation"></i> No user data available.
        </div>
    }
</div>
