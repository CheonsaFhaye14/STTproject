<button class="btn-change-pass" @onclick="() => OpenModal()" disabled="@(!UserId.HasValue)">
    <i class="fa-solid fa-key"></i> Change Password
</button>

@if (ShowPasswordModal)
{
    <div class="cp-overlay" @onclick="() => OnBackdropClick()">
        <div class="cp-modal" @onclick:stopPropagation="true">

            <div class="cp-header">
                <h4><i class="fa-solid fa-key"></i> Change Password</h4>
            </div>

            <div class="cp-body">
                @if (!string.IsNullOrEmpty(PasswordErrorMessage))
                {
                    <div class="cp-alert">
                        <i class="fa-solid fa-circle-exclamation"></i> @PasswordErrorMessage
                    </div>
                }

                @if (ShowConfirmationModal)
                {
                    <p class="cp-confirm-text">Are you sure you want to change your password? This action cannot be undone.</p>
                    <div class="cp-actions">
                        <button class="cp-btn-save" @onclick="() => ChangePasswordAsync()" disabled="@IsSubmitting">
                            @(IsSubmitting ? "Changing..." : "Yes, Change Password")
                        </button>
                        <button class="cp-btn-cancel" @onclick="() => CloseConfirmation()" disabled="@IsSubmitting">
                            Cancel
                        </button>
                    </div>
                }
                else
                {
                    <div class="form-group">
                        <label class="cp-label">Current Password</label>
                        <div class="cp-input-wrapper">
                            <i class="fa-solid fa-lock"></i>
                            <input type="password" class="cp-input" @bind="CurrentPassword" placeholder="Enter current password" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="cp-label">New Password</label>
                        <div class="cp-input-wrapper">
                            <i class="fa-solid fa-lock-open"></i>
                            <input type="password" class="cp-input" @bind="NewPassword" placeholder="Enter new password" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="cp-label">Confirm New Password</label>
                        <div class="cp-input-wrapper">
                            <i class="fa-solid fa-lock-open"></i>
                            <input type="password" class="cp-input" @bind="ConfirmPassword" placeholder="Confirm new password" />
                        </div>
                    </div>
                    <div class="cp-actions">
                        <button class="cp-btn-save" @onclick="() => ShowConfirmationAsync()" disabled="@IsSubmitting">
                            Change Password
                        </button>
                        <button class="cp-btn-cancel" @onclick="() => CloseModal()" disabled="@IsSubmitting">
                            Cancel
                        </button>
                    </div>
                }
            </div>

        </div>
    </div>
}
