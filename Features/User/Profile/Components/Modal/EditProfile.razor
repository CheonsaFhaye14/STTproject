@if (EditingUser != null)
{
    @if (ShowConfirmationModal)
    {
        <div class="confirm-box">
            <p class="confirm-text">Are you sure you want to save these changes to your profile?</p>
            <div class="action-buttons">
                <button class="btn-save" @onclick="OnSaveClick" disabled="@IsSaving">
                    @(IsSaving ? "Saving..." : "Yes, Save Changes")
                </button>
                <button class="btn-cancel" @onclick="() => CloseConfirmation()" disabled="@IsSaving">
                    Cancel
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="edit-mode">
            <div class="form-group">
                <label class="form-label">Username</label>
                <div class="input-wrapper">
                    <i class="fa-solid fa-at" aria-hidden="true"></i>
                    <input type="text" class="form-control" @bind="EditingUser.Username" placeholder="Enter username" />
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Full Name</label>
                <div class="input-wrapper">
                    <i class="fa-solid fa-user" aria-hidden="true"></i>
                    <input type="text" class="form-control" @bind="EditingUser.FullName" placeholder="Enter full name" />
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Email</label>
                <div class="input-wrapper">
                    <i class="fa-solid fa-envelope" aria-hidden="true"></i>
                    <input type="email" class="form-control" @bind="EditingUser.Email" placeholder="Enter email address" />
                </div>
            </div>

            <div class="action-buttons">
                <button class="btn-save" @onclick="ShowConfirmationAsync" disabled="@IsSaving">
                    Save Changes
                </button>
                <button class="btn-cancel" @onclick="OnCancelClick" disabled="@IsSaving">
                    Cancel
                </button>
            </div>
        </div>
    }
}
