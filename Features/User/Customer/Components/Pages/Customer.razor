@page "/customer"

@inject ICustomerService CustomerService
@inject IUserContextService UserContextService


	<TitleHeader Model="Model" SelectedSubDistributorId="SelectedSubDistributorId" OnSubDistributorChanged="HandleSubdChanged" />
	<SubdDetails Model="Model" />
	<CustomerListTable Model="Model" />

@code {
	private CustomerListResponseDto? Model;
	private int? SelectedSubDistributorId;

	protected override async Task OnInitializedAsync()
	{
		if (UserContextService.UserId is int userId)
		{
			Model = await CustomerService.GetCustomersWithBranchesAsync(userId);
			SelectedSubDistributorId = Model?.SubDistributor?.SubDistributorId;
		}
	}

	private async Task HandleSubdChanged(int? newSubdId)
	{
		if (newSubdId == null || UserContextService.UserId is not int userId)
			return;

		var customers = await CustomerService.GetCustomersForSubDistributorAsync(userId, newSubdId.Value);
		if (Model != null)
		{
			Model.Customers = customers;
			var selected = Model.SubDistributors.FirstOrDefault(s => s.SubDistributorId == newSubdId.Value);
			if (selected != null)
				Model.SubDistributor = selected;
		}

		SelectedSubDistributorId = newSubdId;
		StateHasChanged();
	}
}